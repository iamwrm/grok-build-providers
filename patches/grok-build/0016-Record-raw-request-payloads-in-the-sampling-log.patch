From e4064569d1385bdc75e8a05f20b76687cfb740de Mon Sep 17 00:00:00 2001
From: grok-build-providers-verify <verify@invalid>
Date: Mon, 20 Jul 2026 12:00:08 +0800
Subject: [PATCH] Record raw request payloads in the sampling log
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The hidden --log-sampling / GROK_LOG_SAMPLING=1 switch already records
every raw SSE response chunk verbatim in ~/.grok/logs/sampling.jsonl, but
never the request side. Add a request_body event emitted at all six send
sites (chat completions, Responses, Messages; streaming and non-streaming)
after every defaulting and shape function has run, so the log captures the
exact wire payload — including provider-specific request shaping such as
cache_control markers.

Serialization only happens when the log is enabled (cached env check
matching the telemetry layer's truthy values), and a serialization failure
is itself logged rather than propagated: the log can never affect the
request, which serializes independently.
---
 crates/codegen/xai-grok-sampler/src/client.rs | 10 +++
 .../xai-grok-sampler/src/sampling_log.rs      | 64 +++++++++++++++++++
 2 files changed, 74 insertions(+)

diff --git a/crates/codegen/xai-grok-sampler/src/client.rs b/crates/codegen/xai-grok-sampler/src/client.rs
index 64e006b..71795f1 100644
--- a/crates/codegen/xai-grok-sampler/src/client.rs
+++ b/crates/codegen/xai-grok-sampler/src/client.rs
@@ -1030,6 +1030,7 @@ impl SamplingClient {
             deployment_id: payload.x_grok_deployment_id.as_deref(),
             user_id: payload.x_grok_user_id.as_deref(),
         };
+        crate::sampling_log::log_request_body("chat_completions", "chat/completions", &payload);
         let http_request = grok_headers
             .apply(self.post(self.endpoint("chat/completions")))
             .json(&payload);
@@ -1088,6 +1089,11 @@ impl SamplingClient {
             deployment_id: payload.x_grok_deployment_id.as_deref(),
             user_id: payload.x_grok_user_id.as_deref(),
         };
+        crate::sampling_log::log_request_body(
+            "chat_completions",
+            "chat/completions",
+            &streaming_request,
+        );
         let http_request = grok_headers
             .apply(self.post(self.endpoint("chat/completions")))
             .header(ACCEPT, HeaderValue::from_static("text/event-stream"))
@@ -1310,6 +1316,7 @@ impl SamplingClient {
         if self.defaults.auth_scheme == AuthScheme::ChatgptOauth {
             apply_chatgpt_codex_request_shape(&mut request_body);
         }
+        crate::sampling_log::log_request_body("responses", "responses", &request_body);
         let http_request = grok_headers
             .apply(self.post(self.endpoint("responses")))
             .json(&request_body);
@@ -1485,6 +1492,7 @@ impl SamplingClient {
             // Presence opts in; the server ignores the value.
             http_request = http_request.header(DOOM_LOOP_CHECK_HEADER, "true");
         }
+        crate::sampling_log::log_request_body("responses", "responses", &request_body);
         let http_request = http_request.json(&request_body);
 
         let built_request = http_request.build().map_err(|e| {
@@ -1679,6 +1687,7 @@ impl SamplingClient {
             deployment_id: request.x_grok_deployment_id.as_deref(),
             user_id: request.x_grok_user_id.as_deref(),
         };
+        crate::sampling_log::log_request_body("messages", "messages", &request.inner);
         let http_request = grok_headers
             .apply(self.post(self.endpoint("messages")))
             .json(&request.inner);
@@ -1786,6 +1795,7 @@ impl SamplingClient {
             deployment_id: request.x_grok_deployment_id.as_deref(),
             user_id: request.x_grok_user_id.as_deref(),
         };
+        crate::sampling_log::log_request_body("messages", "messages", &request.inner);
         let http_request = grok_headers
             .apply(self.post(self.endpoint("messages")))
             .header(ACCEPT, HeaderValue::from_static("text/event-stream"))
diff --git a/crates/codegen/xai-grok-sampler/src/sampling_log.rs b/crates/codegen/xai-grok-sampler/src/sampling_log.rs
index 69e2eea..3b4bebb 100644
--- a/crates/codegen/xai-grok-sampler/src/sampling_log.rs
+++ b/crates/codegen/xai-grok-sampler/src/sampling_log.rs
@@ -6,6 +6,53 @@ use crate::types::RequestId;
 
 pub const TARGET: &str = "sampling_log";
 
+/// Same switch the `xai-grok-telemetry` sampling layer keys on. The pager's
+/// hidden `--log-sampling` flag sets this env var before telemetry init, so
+/// checking it here is equivalent to asking whether the layer is installed.
+/// Cached: the flag cannot change after startup, and the hot paths below
+/// run once per LLM call.
+pub fn enabled() -> bool {
+    static ENABLED: std::sync::OnceLock<bool> = std::sync::OnceLock::new();
+    *ENABLED.get_or_init(|| parse_enabled(std::env::var("GROK_LOG_SAMPLING").ok().as_deref()))
+}
+
+/// Truthy values accepted by the telemetry layer for `GROK_LOG_SAMPLING`;
+/// keep in sync with `xai-grok-telemetry/src/sampling_log.rs`.
+fn parse_enabled(value: Option<&str>) -> bool {
+    value.is_some_and(|v| matches!(v, "1" | "true" | "on"))
+}
+
+/// Record the exact JSON request payload about to be sent to the provider,
+/// after all defaulting/shape functions ran (i.e. the true wire body).
+/// No-op unless the sampling log is enabled; serialization only happens on
+/// the enabled path. Serialization failures are swallowed — the log must
+/// never affect the request itself, which serializes independently.
+pub fn log_request_body<T: serde::Serialize>(backend: &'static str, endpoint: &str, body: &T) {
+    if !enabled() {
+        return;
+    }
+    match serde_json::to_string(body) {
+        Ok(data) => {
+            tracing::info!(
+                target: TARGET,
+                event = "request_body",
+                backend = backend,
+                endpoint = endpoint,
+                data = %data,
+            );
+        }
+        Err(e) => {
+            tracing::info!(
+                target: TARGET,
+                event = "request_body",
+                backend = backend,
+                endpoint = endpoint,
+                serialize_error = %e,
+            );
+        }
+    }
+}
+
 #[derive(Debug, Clone)]
 pub struct AuthInfo {
     pub auth_type: &'static str,
@@ -35,3 +82,20 @@ pub fn request_span(
         reasoning_tokens = tracing::field::Empty,
     )
 }
+
+#[cfg(test)]
+mod tests {
+    use super::parse_enabled;
+
+    #[test]
+    fn parse_enabled_accepts_layer_truthy_values_only() {
+        assert!(parse_enabled(Some("1")));
+        assert!(parse_enabled(Some("true")));
+        assert!(parse_enabled(Some("on")));
+        assert!(!parse_enabled(Some("0")));
+        assert!(!parse_enabled(Some("false")));
+        assert!(!parse_enabled(Some("yes")));
+        assert!(!parse_enabled(Some("")));
+        assert!(!parse_enabled(None));
+    }
+}

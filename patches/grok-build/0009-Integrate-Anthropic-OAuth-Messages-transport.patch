+/// Claude Code identity block required as the first system block on
+/// Anthropic consumer-OAuth (Claude Pro/Max) requests.
+const CLAUDE_CODE_IDENTITY: &str = "You are Claude Code, Anthropic's official CLI for Claude.";
+
+/// System-prompt fragment rewrites for Anthropic OAuth requests.
+///
+/// Anthropic's consumer-OAuth backend runs a server-side classifier that
+/// rejects system prompts of known third-party coding agents with HTTP 400
+/// ("Third-party apps now draw from your extra usage, not your plan
+/// limits..."). The classifier keys on specific text fragments, not prompt
+/// length or structure. Each entry rewrites the minimal trigger fragment
+/// found by binary-search isolation while preserving the instruction's
+/// intent. Anchors are deliberately short so unrelated wording drift cannot
+/// silently disable a replacement.
+///
+/// Currently empty: no grok-build system-prompt fragment is known to
+/// trigger the classifier. When OAuth requests start failing with the
+/// message above, isolate the trigger per prompt section, add the smallest
+/// passing rewrite here, and document it.
+const ANTHROPIC_OAUTH_SYSTEM_REPLACEMENTS: &[(&str, &str)] = &[];
+
+/// Rewrite a typed Messages request for the Anthropic consumer-OAuth
+/// backend, used by models with [`AuthScheme::AnthropicOauth`]:
+///
+/// * the Claude Code identity block is required as the first system block
+///   (the backend rejects third-party system prompts without it);
+/// * [`ANTHROPIC_OAUTH_SYSTEM_REPLACEMENTS`] is applied to the remaining
+///   system text (classifier workaround);
+/// * sampling params (`temperature`, `top_p`) are stripped when extended
+///   thinking is enabled — the API rejects that combination (and Opus 4.7+
+///   rejects `temperature` outright).
+fn apply_anthropic_oauth_request_shape(request: &mut messages::MessagesRequest) {
+    use messages::{CacheControl, SystemParam, TextBlock, ThinkingConfig};
+
+    let mut blocks: Vec<TextBlock> = match request.system.take() {
+        None => Vec::new(),
+        Some(SystemParam::Text(text)) => vec![TextBlock {
+            r#type: "text".to_string(),
+            text,
+            cache_control: None,
+        }],
+        Some(SystemParam::Blocks(blocks)) => blocks,
+    };
+    for block in &mut blocks {
+        for (from, to) in ANTHROPIC_OAUTH_SYSTEM_REPLACEMENTS {
+            if block.text.contains(from) {
+                block.text = block.text.replace(from, to);
+            }
+        }
+    }
+    if blocks.first().map(|b| b.text.as_str()) != Some(CLAUDE_CODE_IDENTITY) {
+        blocks.insert(
+            0,
+            TextBlock {
+                r#type: "text".to_string(),
+                text: CLAUDE_CODE_IDENTITY.to_string(),
+                cache_control: None,
+            },
+        );
+    }
+    // Keep existing cache markers; when none exist (e.g. no system prompt
+    // at all), cache the trailing block so the identity still prefix-caches.
+    if blocks.iter().all(|b| b.cache_control.is_none())
+        && let Some(last) = blocks.last_mut()
+    {
+        last.cache_control = Some(CacheControl {
+            r#type: "ephemeral".to_string(),
+        });
+    }
+    request.system = Some(SystemParam::Blocks(blocks));
+
+    if !matches!(request.thinking, None | Some(ThinkingConfig::Disabled)) {
+        request.temperature = None;
+        request.top_p = None;
+    }
+}

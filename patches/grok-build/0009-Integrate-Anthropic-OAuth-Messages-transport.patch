+    /// Anthropic OAuth request shape: the Claude Code identity becomes the
+    /// first system block, existing system text and its cache marker are
+    /// preserved, and sampling params are stripped when thinking is on.
+    #[test]
+    fn anthropic_oauth_shape_prepends_identity_and_strips_sampling_params() {
+        use xai_grok_sampling_types::messages::{
+            CacheControl, MessagesRequest, SystemParam, TextBlock, ThinkingConfig,
+            ThinkingDisplay,
+        };
+
+        let mut request = MessagesRequest {
+            model: "claude-opus-4-8".to_string(),
+            system: Some(SystemParam::Blocks(vec![TextBlock {
+                r#type: "text".to_string(),
+                text: "You are Grok.".to_string(),
+                cache_control: Some(CacheControl {
+                    r#type: "ephemeral".to_string(),
+                }),
+            }])),
+            temperature: Some(0.7),
+            top_p: Some(0.9),
+            thinking: Some(ThinkingConfig::Adaptive {
+                display: Some(ThinkingDisplay::Summarized),
+            }),
+            ..Default::default()
+        };
+        apply_anthropic_oauth_request_shape(&mut request);
+
+        let Some(SystemParam::Blocks(blocks)) = &request.system else {
+            panic!("system must be in blocks form");
+        };
+        assert_eq!(blocks.len(), 2);
+        assert_eq!(blocks[0].text, CLAUDE_CODE_IDENTITY);
+        assert!(blocks[0].cache_control.is_none());
+        assert_eq!(blocks[1].text, "You are Grok.");
+        assert!(blocks[1].cache_control.is_some(), "cache marker preserved");
+        assert!(request.temperature.is_none());
+        assert!(request.top_p.is_none());
+    }
+
+    /// No system prompt at all → the identity block is still injected (and
+    /// cached); sampling params survive when thinking is disabled.
+    #[test]
+    fn anthropic_oauth_shape_injects_identity_without_system_prompt() {
+        use xai_grok_sampling_types::messages::{MessagesRequest, SystemParam};
+
+        let mut request = MessagesRequest {
+            model: "claude-sonnet-5".to_string(),
+            temperature: Some(0.5),
+            ..Default::default()
+        };
+        apply_anthropic_oauth_request_shape(&mut request);
+
+        let Some(SystemParam::Blocks(blocks)) = &request.system else {
+            panic!("system must be in blocks form");
+        };
+        assert_eq!(blocks.len(), 1);
+        assert_eq!(blocks[0].text, CLAUDE_CODE_IDENTITY);
+        assert!(blocks[0].cache_control.is_some(), "identity prefix-caches");
+        assert_eq!(request.temperature, Some(0.5), "no thinking → params kept");
+
+        // Idempotent: a second application must not duplicate the identity.
+        apply_anthropic_oauth_request_shape(&mut request);
+        let Some(SystemParam::Blocks(blocks)) = &request.system else {
+            panic!("system must be in blocks form");
+        };
+        assert_eq!(blocks.len(), 1);
+    }
 }

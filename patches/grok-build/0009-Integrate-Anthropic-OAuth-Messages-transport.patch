+/// Fold the Anthropic consumer-OAuth (Claude Code identity) headers into
+/// `extra_headers` for models with `auth_scheme = "anthropic_oauth"`:
+///
+/// * `anthropic-version` — required by the Messages API,
+/// * `anthropic-beta` — opts in to OAuth bearer auth + Claude Code identity,
+/// * `user-agent`/`x-app` — Claude Code client identity (the sampler skips
+///   its own User-Agent when one is provided here).
+///
+/// Explicit user-provided headers win (entries are only inserted when the
+/// key is absent).
+pub fn inject_anthropic_oauth_headers(extra_headers: &mut IndexMap<String, String>) {
+    extra_headers
+        .entry("anthropic-version".to_string())
+        .or_insert_with(|| "2023-06-01".to_string());
+    extra_headers
+        .entry("anthropic-beta".to_string())
+        .or_insert_with(|| crate::auth::anthropic::OAUTH_BETA_HEADER.to_string());
+    extra_headers.entry("user-agent".to_string()).or_insert_with(|| {
+        format!("claude-cli/{}", crate::auth::anthropic::CLAUDE_CODE_VERSION)
+    });
+    extra_headers
+        .entry("x-app".to_string())
+        .or_insert_with(|| "cli".to_string());
+}

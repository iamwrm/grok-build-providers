From b7ee45790d92411726fcbd38163bf6051fd2de47 Mon Sep 17 00:00:00 2001
From: grok-build-providers-verify <verify@invalid>
Date: Mon, 20 Jul 2026 16:56:01 +0800
Subject: [PATCH 10/13] Make the release pager link successfully with MSVC

Raise release PDB pages to the supported 16 KiB maximum and enable link.exe long-symbol truncation for both MSVC targets. Both settings are required for the pager's large public-symbol table to link successfully.
---
 .cargo/config.toml | 20 ++++++++++++++++++--
 1 file changed, 18 insertions(+), 2 deletions(-)

diff --git a/.cargo/config.toml b/.cargo/config.toml
index 912e93e..c5a08b7 100644
--- a/.cargo/config.toml
+++ b/.cargo/config.toml
@@ -59,10 +59,26 @@ rustflags = [
 ]
 
 [target.x86_64-pc-windows-msvc]
-rustflags = ["-C", "force-unwind-tables=yes", "-C", "target-feature=+crt-static"]
+rustflags = [
+    "-C", "force-unwind-tables=yes",
+    "-C", "target-feature=+crt-static",
+    # rustc emits a minimal release PDB even with profile debug info disabled.
+    # The pager's public-symbol table exceeds the default 4 KiB PDB page
+    # capacity (fatal LNK4319); 16 KiB is link.exe's supported maximum.
+    "-C", "link-arg=/PDBPAGESIZE:16384",
+    # The pager also contains generated/generic symbols long enough to hit
+    # LNK4318 and exhaust the PDB public-symbol table even at 16 KiB pages.
+    # Retain useful symbols while truncating only those pathological names.
+    "-C", "link-arg=/DEBUG:LongSymbolTruncate",
+]
 
 [target.aarch64-pc-windows-msvc]
-rustflags = ["-C", "force-unwind-tables=yes", "-C", "target-feature=+crt-static"]
+rustflags = [
+    "-C", "force-unwind-tables=yes",
+    "-C", "target-feature=+crt-static",
+    "-C", "link-arg=/PDBPAGESIZE:16384",
+    "-C", "link-arg=/DEBUG:LongSymbolTruncate",
+]
 
 
 # jemalloc page size for Apple Silicon (macOS aarch64 uses 16KB pages = 2^14).

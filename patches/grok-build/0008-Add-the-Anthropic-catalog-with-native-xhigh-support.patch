+/// Base URL of the Anthropic API; the sampler appends `/messages`.
+pub const ANTHROPIC_MESSAGES_BASE_URL: &str = "https://api.anthropic.com/v1";
+
+/// Built-in Anthropic (Claude Pro/Max) model catalog, keyed
+/// `anthropic/<id>`. Mirrors pi's `anthropic` provider catalog, restricted
+/// to the adaptive-thinking generation (Claude 4.6+): grok-build's Messages
+/// conversion drives thinking exclusively through the adaptive
+/// `output_config.effort` field, which older budget-thinking models reject.
+/// Callers gate on a stored Anthropic credential (`grok anthropic login`)
+/// so the picker doesn't fill with models that cannot work.
+pub fn anthropic_model_entries() -> Vec<(String, ModelEntry)> {
+    // (id, name, context_window, max_completion_tokens)
+    const CLAUDE_CONTEXT: u64 = 1_000_000;
+    let models: [(&str, &str, u64, u32); 6] = [
+        ("claude-opus-4-8", "Claude Opus 4.8", CLAUDE_CONTEXT, 128_000),
+        ("claude-opus-4-7", "Claude Opus 4.7", CLAUDE_CONTEXT, 128_000),
+        ("claude-opus-4-6", "Claude Opus 4.6", CLAUDE_CONTEXT, 128_000),
+        ("claude-sonnet-5", "Claude Sonnet 5", CLAUDE_CONTEXT, 128_000),
+        (
+            "claude-sonnet-4-6",
+            "Claude Sonnet 4.6",
+            CLAUDE_CONTEXT,
+            64_000,
+        ),
+        ("claude-fable-5", "Claude Fable 5", CLAUDE_CONTEXT, 128_000),
+    ];
+    models
+        .into_iter()
+        .map(|(slug, name, context_window, max_completion_tokens)| {
+            let key = format!("anthropic/{slug}");
+            let mut info = ModelInfo::fallback(slug);
+            info.id = Some(key.clone());
+            info.base_url = ANTHROPIC_MESSAGES_BASE_URL.to_string();
+            info.name = Some(format!("{name} (Anthropic)"));
+            info.description = Some("Anthropic Claude via Claude Pro/Max plan".to_string());
+            info.api_backend = ApiBackend::Messages;
+            info.auth_scheme = AuthScheme::AnthropicOauth;
+            info.context_window =
+                NonZeroU64::new(context_window).expect("claude context windows are non-zero");
+            info.max_completion_tokens = Some(max_completion_tokens);
+            info.supports_reasoning_effort = true;
+            info.reasoning_effort = Some(ReasoningEffort::High);
+            let mut efforts = vec![
+                (ReasoningEffort::Low, "low", "Low", false),
+                (ReasoningEffort::Medium, "medium", "Medium", false),
+                (ReasoningEffort::High, "high", "High", true),
+            ];
+            // pi parity (`thinkingLevelMap`): native `xhigh` — a distinct
+            // level between `high` and `max` — exists only on Opus 4.7/4.8,
+            // Sonnet 5, and Fable 5. All adaptive models accept `max`; on
+            // models without a native `xhigh` the effort resolver maps a
+            // requested `xhigh` to the offered `max`.
+            let has_native_xhigh = matches!(
+                slug,
+                "claude-opus-4-8" | "claude-opus-4-7" | "claude-sonnet-5" | "claude-fable-5"
+            );
+            if has_native_xhigh {
+                efforts.push((ReasoningEffort::Xhigh, "xhigh", "Extra high", false));
+            }
+            efforts.push((ReasoningEffort::Max, "max", "Max", false));
+            info.reasoning_efforts = efforts
+                .into_iter()
+                .map(|(value, id, label, default)| ReasoningEffortOption {
+                    id: id.to_string(),
+                    value,
+                    label: label.to_string(),
+                    description: None,
+                    default,
+                })
+                .collect();
+            (
+                key,
+                ModelEntry {
+                    info,
+                    api_key: None,
+                    env_key: None,
+                    api_base_url: None,
+                },
+            )
+        })
+        .collect()
+}

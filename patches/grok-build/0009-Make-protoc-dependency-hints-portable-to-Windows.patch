From 0b54014bdbbbf2332d0cdd3b65a9f7a3e01651f3 Mon Sep 17 00:00:00 2001
From: grok-build-providers-verify <verify@invalid>
Date: Mon, 20 Jul 2026 16:56:01 +0800
Subject: [PATCH 09/14] Make protoc dependency hints portable to Windows

Skip the optional Unix-device-based protoc dependency-hint helper on Windows, where protoc.exe cannot open /dev/stdout or /dev/null. Preserve normal proto generation and dependency hints on Unix.
---
 crates/build/xai-proto-build/src/lib.rs | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/crates/build/xai-proto-build/src/lib.rs b/crates/build/xai-proto-build/src/lib.rs
index 417c4b2..d0a7be5 100644
--- a/crates/build/xai-proto-build/src/lib.rs
+++ b/crates/build/xai-proto-build/src/lib.rs
@@ -103,6 +103,16 @@ impl XaiProtoBuilder {
         protos: impl IntoIterator<Item = &'a Path>,
         includes: impl IntoIterator<Item = &'a Path>,
     ) -> anyhow::Result<()> {
+        // The `--dependency_out=/dev/stdout` / `--descriptor_set_out=/dev/null`
+        // invocation below is unix-only: protoc.exe cannot open device paths on
+        // Windows, and porting the dependency-file parsing would have to cope
+        // with drive-letter colons in the `target:` prefix. The emitted
+        // `rerun-if-changed` hints only speed up incremental local rebuilds,
+        // so skip them on Windows instead (CI/release builds are clean builds).
+        if cfg!(windows) {
+            return Ok(());
+        }
+
         let includes = Vec::from_iter(includes);
 
         if let Some(protoc) = protoc {

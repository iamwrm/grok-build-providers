@@ -1,10 +1,69 @@
 //! Sampling log — emits `tracing` events with `target: "sampling_log"`.
 //! A dedicated layer in `xai-grok-telemetry` routes these to
-//! `~/.grok/logs/sampling.jsonl`. Enable with `--log-sampling`.
+//! `~/.grok/logs/sampling.jsonl`. Enable before startup with `--log-sampling`
+//! or `GROK_LOG_SAMPLING=true`, and at runtime with `/debug sampling on`.
+
+use std::sync::OnceLock;
+use std::sync::atomic::{AtomicBool, Ordering};
 
 use crate::types::RequestId;
 
 pub const TARGET: &str = "sampling_log";
+pub const ENV_VAR: &str = "GROK_LOG_SAMPLING";
+
+/// Process-wide sampling-log gate. The first read initializes it from the
+/// startup environment; `/debug sampling on|off` mutates the same atomic, so
+/// request serialization and telemetry emission cannot drift.
+fn runtime_gate() -> &'static AtomicBool {
+    static ENABLED: OnceLock<AtomicBool> = OnceLock::new();
+    ENABLED.get_or_init(|| AtomicBool::new(parse_enabled(std::env::var(ENV_VAR).ok().as_deref())))
+}
+
+pub fn enabled() -> bool {
+    runtime_gate().load(Ordering::Relaxed)
+}
+
+/// Enable/disable full raw request and response logging at runtime. Returns
+/// the previous state so callers can report whether anything changed.
+pub fn set_enabled(enabled: bool) -> bool {
+    runtime_gate().swap(enabled, Ordering::SeqCst)
+}
+
+/// Truthy startup values accepted for `GROK_LOG_SAMPLING`.
+fn parse_enabled(value: Option<&str>) -> bool {
+    value.is_some_and(|v| matches!(v, "1" | "true" | "on"))
+}
+
+/// Record the exact JSON request payload about to be sent to the provider,
+/// after all defaulting/shape functions ran (i.e. the true wire body).
+/// No-op unless the sampling log is enabled; serialization only happens on
+/// the enabled path. Serialization failures are swallowed — the log must
+/// never affect the request itself, which serializes independently.
+pub fn log_request_body<T: serde::Serialize>(backend: &'static str, endpoint: &str, body: &T) {
+    if !enabled() {
+        return;
+    }
+    match serde_json::to_string(body) {
+        Ok(data) => {
+            tracing::info!(
+                target: TARGET,
+                event = "request_body",
+                backend = backend,
+                endpoint = endpoint,
+                data = %data,
+            );
+        }
+        Err(e) => {
+            tracing::info!(
+                target: TARGET,
+                event = "request_body",
+                backend = backend,
+                endpoint = endpoint,
+                serialize_error = %e,
+            );
+        }
+    }
+}
 
 #[derive(Debug, Clone)]

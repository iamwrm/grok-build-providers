 //! place — and so a viewer that re-attaches mid-turn can finalize the turn from
 //! replay instead of staying stuck on "Waiting…".
 
-use crate::scrollback::blocks::SessionEvent;
+use crate::scrollback::blocks::{SessionEvent, TurnUsageStats};
+
+/// Convert the shell's aggregate prompt usage into the compact TUI stats
+/// payload. The shell keeps full prompt input (uncached + read + write); the
+/// display's ↑ value is the uncached remainder so R/W are not double-counted.
+pub(super) fn turn_usage_stats(
+    usage: Option<&xai_grok_shell::extensions::notification::PromptUsage>,
+    context_start_tokens: Option<u64>,
+    context_end_tokens: Option<u64>,
+    context_window_tokens: Option<u64>,
+) -> Option<TurnUsageStats> {
+    let usage = usage?;
+    let totals = &usage.totals;
+    if totals.model_calls == 0
+        && totals.input_tokens == 0
+        && totals.output_tokens == 0
+        && totals.cached_read_tokens == 0
+        && totals.cached_write_tokens == 0
+    {
+        return None;
+    }
+    let cost_usd_ticks = (!usage.usage_is_incomplete && !totals.cost_is_partial)
+        .then_some(totals.cost_usd_ticks)
+        .flatten();
+    Some(TurnUsageStats {
+        input_tokens: totals
+            .input_tokens
+            .saturating_sub(totals.cached_read_tokens)
+            .saturating_sub(totals.cached_write_tokens),
+        output_tokens: totals.output_tokens,
+        cache_read_tokens: totals.cached_read_tokens,
+        cache_write_tokens: totals.cached_write_tokens,
+        api_duration_ms: totals.api_duration_ms,
+        cost_usd_ticks,
+        context_start_tokens,
+        context_end_tokens,
+        context_window_tokens,
+    })
+}
 

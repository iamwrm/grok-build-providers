-/// Format a token count with "k" suffix for thousands.
+/// Format the compact prompt-cycle usage suffix shown on completed turns.
+fn format_turn_usage(stats: &TurnUsageStats) -> String {
+    let mut parts = Vec::new();
+    if stats.input_tokens > 0 {
+        parts.push(format!("↑{}", format_usage_tokens(stats.input_tokens)));
+    }
+    if stats.output_tokens > 0 {
+        parts.push(format!("↓{}", format_usage_tokens(stats.output_tokens)));
+    }
+    if stats.output_tokens > 0 && stats.api_duration_ms > 0 {
+        let tps = stats.output_tokens as f64 / (stats.api_duration_ms as f64 / 1000.0);
+        parts.push(format!("TPS={tps:.1}"));
+    }
+    if stats.cache_read_tokens > 0 {
+        parts.push(format!("R{}", format_usage_tokens(stats.cache_read_tokens)));
+    }
+    if stats.cache_write_tokens > 0 {
+        parts.push(format!("W{}", format_usage_tokens(stats.cache_write_tokens)));
+    }
+    let prompt_tokens = stats
+        .input_tokens
+        .saturating_add(stats.cache_read_tokens)
+        .saturating_add(stats.cache_write_tokens);
+    if prompt_tokens > 0 && (stats.cache_read_tokens > 0 || stats.cache_write_tokens > 0) {
+        let hit = stats.cache_read_tokens as f64 / prompt_tokens as f64 * 100.0;
+        parts.push(format!("CH{hit:.1}%"));
+    }
+    if let (Some(end), Some(window)) = (stats.context_end_tokens, stats.context_window_tokens)
+        && window > 0
+    {
+        let pct = |tokens: u64| tokens.saturating_mul(100).saturating_add(window / 2) / window;
+        let start = stats
+            .context_start_tokens
+            .map(|tokens| pct(tokens).to_string())
+            .unwrap_or_else(|| "?".to_string());
+        parts.push(format!("CTX{start}:{}", pct(end)));
+    }
+    if let Some(ticks) = stats.cost_usd_ticks.filter(|ticks| *ticks > 0) {
+        parts.push(format!("${:.3}", ticks as f64 / 10_000_000_000.0));
+    }
+    parts.join(" ")

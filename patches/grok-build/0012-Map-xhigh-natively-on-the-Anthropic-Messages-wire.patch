+    /// Symmetric top-level mapping: a requested `xhigh` on a menu without a
+    /// native Xhigh resolves to an offered Max (Claude Opus 4.6 / Sonnet 4.6
+    /// style), and is still rejected when neither top level exists.
+    #[test]
+    fn resolve_effort_token_xhigh_maps_to_max_unless_offered() {
+        let max_only = state_with_meta(Some(serde_json::json!({
+            "supportsReasoningEffort": true,
+            "reasoningEfforts": [
+                { "value": "high", "label": "High" },
+                { "value": "max", "label": "Max" },
+            ],
+        })));
+        assert_eq!(
+            max_only.resolve_effort_token("xhigh"),
+            Some(ReasoningEffort::Max)
+        );
+        // Native xhigh offered → no mapping.
+        let with_both = state_with_meta(Some(serde_json::json!({
+            "supportsReasoningEffort": true,
+            "reasoningEfforts": [
+                { "value": "xhigh", "label": "Extra high" },
+                { "value": "max", "label": "Max" },
+            ],
+        })));
+        assert_eq!(
+            with_both.resolve_effort_token("xhigh"),
+            Some(ReasoningEffort::Xhigh)
+        );
+        // Neither top level → rejected.
+        let low_only = state_with_meta(Some(serde_json::json!({
+            "supportsReasoningEffort": true,
+            "reasoningEfforts": [{ "value": "low", "label": "Low" }],
+        })));
+        assert!(low_only.resolve_effort_token("xhigh").is_none());
+    }
+

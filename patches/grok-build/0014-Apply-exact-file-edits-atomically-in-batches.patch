+async fn apply_edit_in_memory(
+    text: &str,
+    edit: &SearchReplaceEdit,
+    resources: &SharedResources,
+    is_legacy: bool,
+    include_user_edit_hint: bool,
+    path: &std::path::Path,
+) -> Result<
+    Result<(String, Vec<SearchReplaceEditDetail>, bool), SearchReplaceOutput>,
+    xai_tool_runtime::ToolError,
+> {
+    let mut positions: Vec<usize> = text
+        .match_indices(&edit.old_string)
+        .map(|(index, _)| index)
+        .collect();
+    let mut normalized_matches = None;
+    if positions.is_empty() {
+        let fallback_enabled = {
+            let res = resources.lock().await;
+            res.get::<Params<SearchReplaceParams>>()
+                .is_some_and(|p| p.0.unicode_normalized_fallback)
+        };
+        if fallback_enabled {
+            match find_normalized_match_positions(text, &edit.old_string) {
+                NormalizedMatchResult::Matches(matches) => {
+                    if matches.len() > 1 && !edit.replace_all {
+                        let replace_all_name =
+                            TemplateRenderer::resolve(resources, "${{ params.edit.replace_all }}")
+                                .await?;
+                        return Ok(Err(SearchReplaceOutput::MultipleMatchesFound(format!(
+                            "The string to replace was found multiple times in the file (via Unicode normalization). Use {replace_all_name} to replace all occurrences, or include more context to only edit one occurrence."
+                        ))));
+                    }
+                    positions = matches.iter().map(|m| m.original_start).collect();
+                    normalized_matches = Some(matches);
+                }
+                NormalizedMatchResult::Ambiguous => {
+                    let old_string_name =
+                        TemplateRenderer::resolve(resources, "${{ params.edit.old_string }}")
+                            .await?;
+                    return Ok(Err(SearchReplaceOutput::MultipleMatchesFound(format!(
+                        "The string to replace was found via Unicode normalization but the match is ambiguous (partial or overlapping). Use a more specific {old_string_name} that avoids lines with Unicode typography characters."
+                    ))));
+                }
+                NormalizedMatchResult::NoMatch => {}
+            }
+        }
+    }
+    if positions.is_empty() {
+        let (read_name, old_string_param, execute_name) = {
+            let res = resources.lock().await;
+            let renderer = res.require::<TemplateRenderer>()?;
+            let read_name = renderer
+                .render("${{ tools.by_kind.read }}")
+                .map_err(|e| xai_tool_runtime::ToolError::invalid_arguments(e.to_string()))?;
+            let old_string_param = renderer
+                .render("${{ params.edit.old_string }}")
+                .map_err(|e| xai_tool_runtime::ToolError::invalid_arguments(e.to_string()))?;
+            let execute_name = renderer
+                .render("${{ tools.by_kind.execute }}")
+                .map_err(|e| xai_tool_runtime::ToolError::invalid_arguments(e.to_string()))?;
+            (read_name, old_string_param, execute_name)
+        };
+        let hint = if is_legacy {
+            String::new()
+        } else {
+            build_nearest_match_hint(text, &edit.old_string)
+        };
+        let confusable_hint = if is_legacy {
+            String::new()
+        } else {
+            build_confusable_hint(
+                text,
+                &edit.old_string,
+                crate::util::query_tools::QueryTools::detect(),
+                &read_name,
+                &old_string_param,
+                &execute_name,
+            )
+            .unwrap_or_default()
+        };
+        let user_edit_hint = if include_user_edit_hint {
+            " The user may have changed the file since you last read it."
+        } else {
+            ""
+        };
+        return Ok(Err(SearchReplaceOutput::NoMatchesFound(
+            crate::types::output::NoMatchesFoundError {
+                message: format!(
+                    "The string to replace was not found in the file, use the {read_name} tool to see the correct string.{user_edit_hint}{hint}{confusable_hint}"
+                ),
+                file_path: path.to_path_buf(),
+                file_snapshot_at_edit: None,
+            },
+        )));
+    }
+    if positions.len() > 1 && !edit.replace_all {
+        let replace_all_name =
+            TemplateRenderer::resolve(resources, "${{ params.edit.replace_all }}").await?;
+        return Ok(Err(SearchReplaceOutput::MultipleMatchesFound(format!(
+            "The string to replace was found multiple times in the file. Use {replace_all_name} to replace all occurrences, or include more context to only edit one occurrence."
+        ))));
+    }
+    let used_normalized_fallback = normalized_matches.is_some();
+    let (new_text, new_positions) = if let Some(matches) = normalized_matches {
+        replace_normalized_matches(text, &matches, &edit.new_string)
+    } else {
+        replace_using_positions(text, &positions, &edit.old_string, &edit.new_string)
+    };
+    let details = build_edit_details(
+        &new_text,
+        &edit.old_string,
+        &edit.new_string,
+        &new_positions,
+        CONTEXT_LINES,
+    );
+    Ok(Ok((new_text, details, used_normalized_fallback)))
+}

+        let assistant = ConversationItem::assistant_tool_calls(vec![ToolCall {
+            id: Arc::from("call_abc|fc_xyz"),
+            name: "read_file".into(),
+            arguments: Arc::from(r#"{"path":"a.rs"}"#),
+        }]);
+        let result = ConversationItem::tool_result("call_abc|fc_xyz", "ok");
+        let req =
+            ConversationRequest::from_items(vec![ConversationItem::user("hi"), assistant, result]);
+        let resp: rs::CreateResponse = (&req).into();
+        assert_eq!(resp.parallel_tool_calls, Some(true));
+        let rs::InputParam::Items(items) = resp.input else {
+            panic!("expected items input");
+        };
+        let fc = items.iter().find_map(|item| match item {
+            rs::InputItem::Item(rs::Item::FunctionCall(fc)) => Some(fc),
+            _ => None,

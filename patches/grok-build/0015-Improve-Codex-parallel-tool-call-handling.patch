+/// Build a Responses-compatible tool-call id, preserving the item id when
+/// present (pi-style `call_id|fc_id`).
+pub fn encode_responses_tool_call_id(call_id: &str, item_id: Option<&str>) -> String {
+    match item_id.map(str::trim).filter(|id| !id.is_empty()) {
+        Some(item_id) => format!("{call_id}|{item_id}"),
+        None => call_id.to_owned(),
+    }
+}
+
+/// Split a stored tool-call id into `(call_id, optional item_id)`.
+///
+/// Plain `call_…` ids (Chat Completions, legacy sessions) return
+/// `(id, None)`. Compound Responses ids return both parts.
+pub fn responses_tool_call_parts(id: &str) -> (&str, Option<&str>) {
+    match id.split_once('|') {
+        Some((call_id, item_id)) if !call_id.is_empty() && !item_id.is_empty() => {
+            (call_id, Some(item_id))
+        }
+        _ => (id, None),
+    }
+}

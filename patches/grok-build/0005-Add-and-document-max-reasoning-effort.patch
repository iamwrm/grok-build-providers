+/// Restore the literal `"max"` reasoning effort on a serialized Responses
+/// request body.
+///
+/// async-openai's `rs::ReasoningEffort` has no `Max` variant, so
+/// [`crate::ReasoningEffort::to_responses_api`] downgrades `Max` to `Xhigh`
+/// in the typed request as a placeholder. Callers that serialize the typed
+/// request must pass the **canonical** effort here to put the real wire
+/// value back. No-op unless `effort` is `Some(Max)`.
+///
+/// Like [`patch_reasoning_text_types`], this papers over an async-openai
+/// gap; when upstream grows a `Max` variant this function can be deleted.
+pub fn patch_reasoning_effort_max(
+    body: &mut serde_json::Value,
+    effort: Option<crate::ReasoningEffort>,
+) {
+    if effort != Some(crate::ReasoningEffort::Max) {
+        return;
+    }
+    let Some(obj) = body.as_object_mut() else {
+        return;
+    };
+    let reasoning = obj
+        .entry("reasoning")
+        .or_insert_with(|| serde_json::Value::Object(serde_json::Map::new()));
+    if let Some(reasoning) = reasoning.as_object_mut() {
+        reasoning.insert(
+            "effort".to_string(),
+            serde_json::Value::String("max".to_string()),
+        );
+    }
+}
+
+/// Metadata key holding the raw wire `reasoning.effort` string when the
+/// typed `rs::ReasoningEffort` cannot represent it (currently `"max"`).
+/// Written by [`sanitize_unknown_reasoning_effort`], read by
+/// [`response_to_conversation_items`] for effort provenance.
+pub const REASONING_EFFORT_WIRE_METADATA_KEY: &str = "reasoning_effort_wire";
+
+/// Make a raw Responses API **response** JSON object parseable by
+/// async-openai when the server echoes a `reasoning.effort` the typed enum
+/// does not know (e.g. `"max"`, which async-openai lacks).
+///
+/// The unknown effort string is stashed into
+/// `metadata[`[`REASONING_EFFORT_WIRE_METADATA_KEY`]`]` and the field is
+/// rewritten to `"xhigh"` so `serde_json::from_value::<rs::Response>`
+/// succeeds; [`response_to_conversation_items`] prefers the stashed raw
+/// value when stamping per-response effort provenance. No-op when the
+/// effort is absent or already parseable.
+pub fn sanitize_unknown_reasoning_effort(response: &mut serde_json::Value) {
+    let Some(effort) = response
+        .pointer("/reasoning/effort")
+        .and_then(|v| v.as_str())
+        .map(str::to_owned)
+    else {
+        return;
+    };
+    if serde_json::from_value::<rs::ReasoningEffort>(serde_json::Value::String(effort.clone()))
+        .is_ok()
+    {
+        return;
+    }
+    let Some(obj) = response.as_object_mut() else {
+        return;
+    };
+    let metadata = obj
+        .entry("metadata")
+        .or_insert_with(|| serde_json::Value::Object(serde_json::Map::new()));
+    if let Some(metadata) = metadata.as_object_mut() {
+        metadata.insert(
+            REASONING_EFFORT_WIRE_METADATA_KEY.to_string(),
+            serde_json::Value::String(effort),
+        );
+    }
+    if let Some(e) = obj
+        .get_mut("reasoning")
+        .and_then(|r| r.get_mut("effort"))
+    {
+        *e = serde_json::Value::String("xhigh".to_string());
+    }
+}

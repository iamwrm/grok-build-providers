+    #[test]
+    fn streaming_text_fallback_does_not_overwrite_terminal_text() {
+        let mut items = vec![ConversationItem::assistant("terminal")];
+        inject_streaming_text_fallback(&mut items, "streamed".to_string());
+        assert!(matches!(
+            items.as_slice(),
+            [ConversationItem::Assistant(a)] if a.content.as_ref() == "terminal"
+        ));
+    }

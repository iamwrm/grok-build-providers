+        // from the terminal response's `output`. Keep the streamed text so we
+        // can synthesize the final Assistant item instead of classifying a
+        // response already shown to the user as empty and retrying it.
+        let mut text_acc = String::new();
         let mut reasoning_acc = String::new();
         let mut last_content_chunk_at = Instant::now();
 
@@ -194,6 +200,7 @@ pub fn stream_responses<'a>(
                         chunk_timestamps.push(Instant::now());
                         chunk_index += 1;
                         message_chunk_count += 1;
+                        text_acc.push_str(&delta);
                         yield SamplingEvent::ChannelToken {
                             request_id: request_id.clone(),
                             channel: SamplingChannel::Text,
@@ -203,6 +210,30 @@ pub fn stream_responses<'a>(
                     }
                 }
 
+                // Usually redundant with preceding deltas. Some compatible
+                // backends only send the done event; surface and retain it in
+                // that case, but never duplicate a delta-assembled response.
+                ResponseStreamEvent::ResponseOutputTextDone(done_event) => {
+                    if text_acc.is_empty() && !done_event.text.is_empty() {
+                        if !first_token_emitted {
+                            first_token_emitted = true;
+                            yield SamplingEvent::FirstToken {
+                                request_id: request_id.clone(),

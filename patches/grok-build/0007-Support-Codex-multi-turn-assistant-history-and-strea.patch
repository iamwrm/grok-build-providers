+/// Convert a prior assistant easy-input message into the completed output
+/// message shape used by pi/the Codex client:
+///
+/// `{type:message, role:assistant, content:[{type:output_text, ...}],
+///   status:completed, id:msg_grok_N}`.
+fn normalize_codex_assistant_history_item(item: &mut serde_json::Value, index: usize) {
+    let Some(message) = item.as_object_mut() else {
+        return;
+    };
+    if message.get("role").and_then(|r| r.as_str()) != Some("assistant") {
+        return;
+    }
+    let Some(content) = message.get("content").cloned() else {
+        return;
+    };
+    let output_parts: Vec<serde_json::Value> = match content {
+        serde_json::Value::String(text) if !text.is_empty() => {
+            vec![codex_output_text_part(text)]
+        }
+        serde_json::Value::Array(parts) => parts
+            .into_iter()
+            .filter_map(|part| {
+                let text = part
+                    .get("text")
+                    .and_then(|v| v.as_str())
+                    .filter(|text| !text.is_empty())?;
+                Some(codex_output_text_part(text.to_string()))
+            })
+            .collect(),
+        _ => Vec::new(),
+    };
+    if output_parts.is_empty() {
+        return;
+    }
+    message.insert(
+        "content".to_string(),
+        serde_json::Value::Array(output_parts),
+    );
+    message.insert(
+        "type".to_string(),
+        serde_json::Value::String("message".to_string()),
+    );
+    message.insert(
+        "status".to_string(),
+        serde_json::Value::String("completed".to_string()),
+    );
+    message
+        .entry("id".to_string())
+        .or_insert_with(|| serde_json::Value::String(format!("msg_grok_{index}")));
+}
+
+fn codex_output_text_part(text: String) -> serde_json::Value {
+    serde_json::json!({
+        "type": "output_text",
+        "text": text,
+        "annotations": [],
+    })
+}

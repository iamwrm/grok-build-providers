+/// Preserve complete function calls observed in stream events when the
+/// terminal response omits its output. Typed terminal tool calls win.
+fn inject_streaming_tool_fallback(
+    items: &mut Vec<ConversationItem>,
+    streamed: BTreeMap<u32, rs::FunctionToolCall>,
+) {
+    if streamed.is_empty()
+        || items
+            .iter()
+            .any(|item| matches!(item, ConversationItem::Assistant(a) if !a.tool_calls.is_empty()))
+    {
+        return;
+    }
+    let tool_calls: Vec<ToolCall> = streamed
+        .into_values()
+        .map(|call| ToolCall {
+            id: Arc::from(call.call_id),
+            name: call.name,
+            arguments: Arc::from(call.arguments),
+        })
+        .collect();
+    if let Some(ConversationItem::Assistant(assistant)) = items
+        .iter_mut()
+        .rev()
+        .find(|item| matches!(item, ConversationItem::Assistant(_)))
+    {
+        assistant.tool_calls = tool_calls;
+    } else {
+        items.push(ConversationItem::assistant_tool_calls(tool_calls));
+    }
+}
+

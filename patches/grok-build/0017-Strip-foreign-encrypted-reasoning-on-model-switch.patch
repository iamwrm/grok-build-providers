+        // Visible summary folded into the assistant message text.
+        let assistant_texts: Vec<&str> = input
+            .iter()
+            .filter_map(|v| {
+                if v.get("role").and_then(|r| r.as_str()) == Some("assistant") {
+                    v.get("content").and_then(|c| c.as_str())
+                } else {
+                    None
+                }
+            })
             .collect();
-        assert_eq!(reasoning.len(), 1, "summary-bearing foreign reasoning kept");
         assert!(
-            reasoning[0].get("encrypted_content").is_none()
-                || reasoning[0]
-                    .get("encrypted_content")
-                    .is_some_and(|v| v.is_null()),
-            "foreign encrypted_content must be stripped, got: {}",
-            reasoning[0]
+            assistant_texts
+                .iter()
+                .any(|t| t.contains("visible summary") && t.contains("answer")),
+            "foreign CoT text must fold into assistant content, got {assistant_texts:?}"
         );
-        // Visible summary survives so the new model still sees CoT text.
-        let summary_text = reasoning[0]
-            .pointer("/summary/0/text")
-            .and_then(|v| v.as_str());
-        assert_eq!(summary_text, Some("visible summary"));
+        assert!(
+            !serde_json::to_string(&input)
+                .unwrap()
+                .contains("rs_grok_1"),
+            "foreign rs_* id must not appear on the wire"
+        );
+        assert!(
+            !serde_json::to_string(&input)
+                .unwrap()
+                .contains("enc_from_grok"),
+            "foreign encrypted_content must not appear on the wire"
+        );
+    }
+
+    /// Foreign reasoning with only a summary (no encrypted blob) still must
+    /// not emit a typed reasoning item with an `rs_*` id.
+    #[test]
+    fn build_responses_input_clears_foreign_reasoning_id_without_encrypted() {
+        let items = vec![
+            ConversationItem::user("hi"),
+            reasoning_sibling("rs_foreign_summary_only", "just a summary", None),
+            ConversationItem::assistant_with_model("answer", "grok-4.5"),
+            ConversationItem::user("continue on gpt"),
+        ];
+        let req = ConversationRequest::from_items(items).with_model("gpt-5.6-sol");
+        let input = input_items_json(&req);
+        let reasoning_count = input
+            .iter()
+            .filter(|v| v.get("type").and_then(|t| t.as_str()) == Some("reasoning"))
+            .count();
+        assert_eq!(reasoning_count, 0);
+        let body = serde_json::to_string(&input).unwrap();
+        assert!(!body.contains("rs_foreign_summary_only"));
+        assert!(body.contains("just a summary"));
     }
 
     /// Encrypted-only foreign reasoning (no user-visible summary) is dropped

From 1397b637c95988df494702d2f543a1ac3d1967cc Mon Sep 17 00:00:00 2001
From: grok-build-providers-verify <verify@invalid>
Date: Mon, 20 Jul 2026 20:53:38 +0800
Subject: [PATCH] Strip foreign encrypted reasoning on mid-session model switch

Responses encrypted_content is model-bound. Replaying Grok rs_* blobs
to Codex/OpenAI after /model switch caused 400 "could not be verified".

Wire-time sanitize (pi-style same-model gate): when the following
assistant's model_id differs from the request model, strip
encrypted_content and drop encrypted-only items. History is unchanged
so switching back still works.
---
 .../src/conversation.rs                       | 175 +++++++++++++++++-
 1 file changed, 173 insertions(+), 2 deletions(-)

diff --git a/crates/codegen/xai-grok-sampling-types/src/conversation.rs b/crates/codegen/xai-grok-sampling-types/src/conversation.rs
index b7af318..62d7807 100644
--- a/crates/codegen/xai-grok-sampling-types/src/conversation.rs
+++ b/crates/codegen/xai-grok-sampling-types/src/conversation.rs
@@ -2251,15 +2251,104 @@ impl From<&ConversationRequest> for rs::CreateResponse {
 /// Reasoning items are top-level siblings (not bundled into the assistant),
 /// so they appear inline in the same order the model originally emitted —
 /// which is what lets the server-side prefix KV-cache hit on repeat turns.
+///
+/// Foreign-model encrypted reasoning is dropped first (see
+/// [`sanitize_reasoning_for_current_model`]) so mid-session model switches
+/// do not replay `encrypted_content` the destination cannot decrypt.
 fn build_responses_input(req: &ConversationRequest) -> rs::InputParam {
-    let items: Vec<rs::InputItem> = req
-        .items
+    let sanitized = sanitize_reasoning_for_current_model(&req.items, req.model.as_deref());
+    let items: Vec<rs::InputItem> = sanitized
         .iter()
         .flat_map(conversation_item_to_input_items)
         .collect();
     rs::InputParam::Items(items)
 }
 
+/// Whether a reasoning item still carries anything the Responses API can
+/// usefully accept after foreign encrypted blobs are removed.
+fn reasoning_item_has_replayable_payload(r: &rs::ReasoningItem) -> bool {
+    r.encrypted_content
+        .as_ref()
+        .is_some_and(|s| !s.is_empty())
+        || !reasoning_item_text(r).trim().is_empty()
+}
+
+/// Look ahead from a reasoning sibling to the assistant turn it belongs to
+/// and return that turn's `model_id`.
+///
+/// Reasoning / backend-tool-call siblings sit immediately before their
+/// assistant; a user/system message means the reasoning was orphaned.
+fn source_model_for_reasoning_at(items: &[ConversationItem], idx: usize) -> Option<&str> {
+    for item in items.iter().skip(idx + 1) {
+        match item {
+            ConversationItem::Assistant(a) => return a.model_id.as_deref(),
+            ConversationItem::Reasoning(_) | ConversationItem::BackendToolCall(_) => continue,
+            ConversationItem::System(_)
+            | ConversationItem::User(_)
+            | ConversationItem::ToolResult(_) => return None,
+        }
+    }
+    None
+}
+
+/// True when encrypted reasoning from `source_model` may be replayed to
+/// `current_model`. Matches pi's same-model gate: exact model id match.
+///
+/// Unknown provenance (`source_model` / `current_model` missing) keeps
+/// encrypted content so legacy sessions and synthetic assistants without a
+/// stamped `model_id` still hit the KV-cache on the same backend.
+fn encrypted_reasoning_compatible(
+    source_model: Option<&str>,
+    current_model: Option<&str>,
+) -> bool {
+    match (source_model, current_model) {
+        (Some(src), Some(cur)) => src == cur,
+        _ => true,
+    }
+}
+
+/// Drop or scrub foreign-model encrypted reasoning for a Responses request.
+///
+/// pi's `transformMessages` drops redacted / signed thinking unless
+/// `assistant.provider + api + model` match the target model. We only stamp
+/// `model_id` on assistants, so the gate is exact `model_id` equality —
+/// enough to stop Grok `rs_*` / `encrypted_content` from being sent to
+/// Codex/OpenAI (and vice versa) after a mid-session `/model` switch.
+///
+/// Wire-time only: the on-disk / in-memory chat history is left intact so
+/// switching *back* to the original model can still replay its encrypted
+/// blobs.
+fn sanitize_reasoning_for_current_model(
+    items: &[ConversationItem],
+    current_model: Option<&str>,
+) -> Vec<ConversationItem> {
+    let mut out = Vec::with_capacity(items.len());
+    for (idx, item) in items.iter().enumerate() {
+        match item {
+            ConversationItem::Reasoning(r) => {
+                let source = source_model_for_reasoning_at(items, idx);
+                if encrypted_reasoning_compatible(source, current_model)
+                    || r.encrypted_content.is_none()
+                {
+                    out.push(item.clone());
+                    continue;
+                }
+                // Foreign encrypted blob: strip it (like pi drops redacted
+                // thinking). Keep summary/content text when present so the
+                // destination still sees visible chain-of-thought; drop the
+                // item entirely when only the opaque blob remained.
+                let mut scrubbed = r.clone();
+                scrubbed.encrypted_content = None;
+                if reasoning_item_has_replayable_payload(&scrubbed) {
+                    out.push(ConversationItem::Reasoning(scrubbed));
+                }
+            }
+            other => out.push(other.clone()),
+        }
+    }
+    out
+}
+
 /// Walk a serialized Responses API request body and inject the
 /// `type: "reasoning_text"` discriminator that the API requires on
 /// `reasoning.content[*]` items.
@@ -9462,6 +9551,88 @@ mod tests {
         assert_eq!(enc_seen, vec!["enc1", "enc2", "enc3"]);
     }
 
+    /// Mid-session model switch (e.g. Grok → Codex): encrypted reasoning
+    /// from the prior model must not be replayed. Matches pi's
+    /// `transformMessages` same-model gate for redacted/signed thinking.
+    #[test]
+    fn build_responses_input_strips_foreign_encrypted_reasoning_on_model_switch() {
+        let items = vec![
+            ConversationItem::user("hi"),
+            reasoning_sibling("rs_grok_1", "visible summary", Some("enc_from_grok")),
+            ConversationItem::assistant_with_model("answer", "grok-4.5"),
+            ConversationItem::user("switch models and continue"),
+        ];
+        let req = ConversationRequest::from_items(items).with_model("gpt-5.6-sol");
+        let input = input_items_json(&req);
+
+        let reasoning: Vec<&serde_json::Value> = input
+            .iter()
+            .filter(|v| v.get("type").and_then(|t| t.as_str()) == Some("reasoning"))
+            .collect();
+        assert_eq!(reasoning.len(), 1, "summary-bearing foreign reasoning kept");
+        assert!(
+            reasoning[0].get("encrypted_content").is_none()
+                || reasoning[0]
+                    .get("encrypted_content")
+                    .is_some_and(|v| v.is_null()),
+            "foreign encrypted_content must be stripped, got: {}",
+            reasoning[0]
+        );
+        // Visible summary survives so the new model still sees CoT text.
+        let summary_text = reasoning[0]
+            .pointer("/summary/0/text")
+            .and_then(|v| v.as_str());
+        assert_eq!(summary_text, Some("visible summary"));
+    }
+
+    /// Encrypted-only foreign reasoning (no user-visible summary) is dropped
+    /// entirely — replaying an empty shell with a foreign `rs_*` id is
+    /// useless and risks further pairing validation failures.
+    #[test]
+    fn build_responses_input_drops_encrypted_only_foreign_reasoning() {
+        let items = vec![
+            ConversationItem::user("hi"),
+            ConversationItem::Reasoning(rs::ReasoningItem {
+                id: "rs_foreign_enc_only".into(),
+                summary: vec![],
+                content: None,
+                encrypted_content: Some("enc_only_blob".into()),
+                status: None,
+            }),
+            ConversationItem::assistant_with_model("answer", "grok-4.5"),
+            ConversationItem::user("continue on gpt"),
+        ];
+        let req = ConversationRequest::from_items(items).with_model("gpt-5.6-sol");
+        let input = input_items_json(&req);
+        let reasoning_count = input
+            .iter()
+            .filter(|v| v.get("type").and_then(|t| t.as_str()) == Some("reasoning"))
+            .count();
+        assert_eq!(
+            reasoning_count, 0,
+            "encrypted-only foreign reasoning must be dropped"
+        );
+    }
+
+    /// Same model keeps encrypted_content byte-stable (KV-cache / CoT replay).
+    #[test]
+    fn build_responses_input_keeps_same_model_encrypted_reasoning() {
+        let items = vec![
+            ConversationItem::user("hi"),
+            reasoning_sibling("rs_same", "think", Some("enc_keep")),
+            ConversationItem::assistant_with_model("answer", "gpt-5.6-sol"),
+            ConversationItem::user("again"),
+        ];
+        let req = ConversationRequest::from_items(items).with_model("gpt-5.6-sol");
+        let input = input_items_json(&req);
+        let enc = input
+            .iter()
+            .find(|v| v.get("type").and_then(|t| t.as_str()) == Some("reasoning"))
+            .and_then(|v| v.get("encrypted_content"))
+            .and_then(|v| v.as_str());
+        assert_eq!(enc, Some("enc_keep"));
+    }
+
     /// INVARIANT: prefix stability across turns without reasoning.
     /// Context and instructions must be prefixed once and consistently
     /// across requests.

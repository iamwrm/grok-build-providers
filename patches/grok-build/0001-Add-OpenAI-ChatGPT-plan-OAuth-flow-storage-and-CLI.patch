+// ============================================================================
+// Device-code login (headless)
+// ============================================================================
+
+#[derive(Debug, Deserialize)]
+struct DeviceAuthResponse {
+    device_auth_id: String,
+    user_code: String,
+    #[serde(default)]
+    interval: Option<serde_json::Value>,
+}
+
+#[derive(Debug, Deserialize)]
+struct DeviceTokenResponse {
+    authorization_code: String,
+    code_verifier: String,
+}
+
+async fn login_device_code() -> anyhow::Result<OpenAiCodexCredential> {
+    let client = reqwest::Client::new();
+    let response = client
+        .post(device_usercode_url())
+        .json(&serde_json::json!({ "client_id": CLIENT_ID }))
+        .send()
+        .await
+        .context("OpenAI device-code request failed")?;
+    if response.status() == StatusCode::NOT_FOUND {
+        bail!("OpenAI device-code login is not enabled for this server. Use browser login.");
+    }
+    if !response.status().is_success() {
+        let status = response.status();
+        let body = response.text().await.unwrap_or_default();
+        bail!("OpenAI device-code request failed ({status}): {body}");
+    }
+    let device: DeviceAuthResponse = response
+        .json()
+        .await
+        .context("invalid OpenAI device-code response")?;
+    let interval_secs = device
+        .interval
+        .as_ref()
+        .and_then(|v| match v {
+            serde_json::Value::Number(n) => n.as_f64(),
+            serde_json::Value::String(s) => s.trim().parse::<f64>().ok(),
+            _ => None,
+        })
+        .filter(|s| s.is_finite() && *s >= 0.0)
+        .unwrap_or(5.0);
+
+    eprintln!();
+    eprintln!("To sign in, open: {}", device_verification_uri());
+    eprintln!("and enter code: {}", device.user_code);
+    eprintln!();
+
+    let deadline = std::time::Instant::now() + DEVICE_CODE_TIMEOUT;
+    let mut interval = std::time::Duration::from_secs_f64(interval_secs.max(1.0));
+    let tokens: DeviceTokenResponse = loop {
+        if std::time::Instant::now() >= deadline {
+            bail!("OpenAI device-code login timed out");
+        }
+        tokio::time::sleep(interval).await;
+        let response = client
+            .post(device_token_url())
+            .json(&serde_json::json!({
+                "device_auth_id": device.device_auth_id,
+                "user_code": device.user_code,
+            }))
+            .send()
+            .await
+            .context("OpenAI device-code poll failed")?;
+        let status = response.status();
+        if status.is_success() {
+            break response
+                .json()
+                .await
+                .context("invalid OpenAI device-auth token response")?;
+        }
+        if status == StatusCode::FORBIDDEN || status == StatusCode::NOT_FOUND {
+            continue; // still pending
+        }
+        let body = response.text().await.unwrap_or_default();
+        let error_code = serde_json::from_str::<serde_json::Value>(&body)
+            .ok()
+            .and_then(|v| {
+                let e = v.get("error")?;
+                e.as_str()
+                    .map(str::to_owned)
+                    .or_else(|| e.get("code")?.as_str().map(str::to_owned))
+            });
+        match error_code.as_deref() {
+            Some("deviceauth_authorization_pending") => continue,
+            Some("slow_down") => {
+                interval += std::time::Duration::from_secs(5);
+                continue;
+            }
+            _ => bail!("OpenAI device-code login failed ({status}): {body}"),
+        }
+    };
+
+    exchange_authorization_code(
+        &tokens.authorization_code,
+        &tokens.code_verifier,
+        &device_redirect_uri(),
+    )
+    .await
+}
+
+// ============================================================================
+// CLI entry points
+// ============================================================================
+
+/// `grok openai login [--device-code]`
+pub async fn run_cli_login(device_auth: bool) -> anyhow::Result<()> {
+    let cred = if device_auth {
+        login_device_code().await?
+    } else {
+        login_browser().await?
+    };
+    store_credential(&cred)?;
+    eprintln!();
+    eprintln!(
+        "Signed in to OpenAI (account {}). Credential saved to {}.",
+        cred.account_id,
+        credential_path().display()
+    );
+    eprintln!("Switch models with `/model openai-codex/<model>` inside Grok.");
+    Ok(())
+}
+
+/// `grok openai logout`
+pub fn run_cli_logout() -> anyhow::Result<()> {
+    if clear_credential()? {
+        eprintln!(
+            "Signed out of OpenAI; removed {}.",
+            credential_path().display()
+        );
+    } else {
+        eprintln!("No OpenAI credential to remove.");
+    }
+    Ok(())
+}
+
+/// `grok openai status`
+pub fn run_cli_status() -> anyhow::Result<()> {
+    match read_credential() {
+        Some(cred) => {
+            let expires = chrono::DateTime::from_timestamp(cred.expires_at, 0)
+                .map(|t| t.to_rfc3339())
+                .unwrap_or_else(|| cred.expires_at.to_string());
+            println!("Signed in to OpenAI (ChatGPT).");
+            println!("  account_id: {}", cred.account_id);
+            println!(
+                "  access token: {}expired (expires {expires})",
+                if cred.is_expired_or_near() {
+                    ""
+                } else {
+                    "not "
+                }
+            );
+            println!("  credential file: {}", credential_path().display());
+        }
+        None => {
+            println!("Not signed in to OpenAI. Run `grok openai login`.");
+        }
+    }
+    Ok(())
+}

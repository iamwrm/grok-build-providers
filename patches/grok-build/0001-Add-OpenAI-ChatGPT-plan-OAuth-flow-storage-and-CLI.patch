+//! OpenAI Codex (ChatGPT Plus/Pro) OAuth.
+//!
+//! Reimplements the ChatGPT-plan OAuth flow used by the official Codex CLI
+//! (and by pi's `openai-codex` provider): PKCE authorization-code flow against
+//! `auth.openai.com` with a fixed loopback callback on port 1455, plus a
+//! device-code flow for headless environments.
+//!
+//! The resulting access token is used as the bearer for requests to the
+//! ChatGPT Codex backend (`https://chatgpt.com/backend-api/codex`), together
+//! with the `chatgpt-account-id` extracted from the access-token JWT.
+//!
+//! Credentials are stored in `~/.grok/openai_auth.json` (owner-only), separate
+//! from the xAI session in `auth.json`: this is a per-provider model
+//! credential, not the Grok session.
+
+use std::collections::HashMap;
+use std::io::IsTerminal;
+use std::path::PathBuf;
+use std::sync::Mutex;
+
+use anyhow::{Context, anyhow, bail};
+use axum::{
+    Router,
+    extract::{Query, State},
+    http::StatusCode,
+    response::Html,
+    routing::get,
+};
+use base64::Engine;
+use base64::engine::general_purpose::URL_SAFE_NO_PAD;
+use chrono::Utc;
+use serde::{Deserialize, Serialize};
+use sha2::{Digest, Sha256};
+use tokio::net::TcpListener;
+
+const CLIENT_ID: &str = "app_EMoamEEZ73f0CkXaXp7hrann";
+const AUTH_BASE_URL: &str = "https://auth.openai.com";
+/// Fixed loopback callback registered for [`CLIENT_ID`]; the port must be 1455.
+const REDIRECT_URI: &str = "http://localhost:1455/auth/callback";
+const CALLBACK_PORT: u16 = 1455;
+const SCOPE: &str = "openid profile email offline_access";
+/// JWT claim namespace carrying `chatgpt_account_id`.
+const JWT_CLAIM_PATH: &str = "https://api.openai.com/auth";
+/// Sent as the `originator` on the authorize URL. `codex_cli_rs` is the
+/// official Codex CLI's value; the backend gates some flows on known
+/// originators.
+const ORIGINATOR: &str = "codex_cli_rs";
+/// Refresh this long before expiry.
+const EARLY_REFRESH_SECS: i64 = 300;
+/// Maximum time to wait for the browser callback / pasted code.
+const AUTH_CALLBACK_TIMEOUT: std::time::Duration = std::time::Duration::from_secs(600);
+/// Device-code flow gives the user this long to approve.
+const DEVICE_CODE_TIMEOUT: std::time::Duration = std::time::Duration::from_secs(15 * 60);
+
+fn authorize_url() -> String {
+    format!("{AUTH_BASE_URL}/oauth/authorize")
+}
+fn token_url() -> String {
+    format!("{AUTH_BASE_URL}/oauth/token")
+}
+fn device_usercode_url() -> String {
+    format!("{AUTH_BASE_URL}/api/accounts/deviceauth/usercode")
+}
+fn device_token_url() -> String {
+    format!("{AUTH_BASE_URL}/api/accounts/deviceauth/token")
+}
+fn device_verification_uri() -> String {
+    format!("{AUTH_BASE_URL}/codex/device")
+}
+fn device_redirect_uri() -> String {
+    format!("{AUTH_BASE_URL}/deviceauth/callback")
+}
+
+// ============================================================================
+// Credential storage
+// ============================================================================
+
+/// Stored ChatGPT OAuth credential.
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+pub struct OpenAiCodexCredential {
+    pub access_token: String,
+    pub refresh_token: String,
+    /// Unix seconds when `access_token` expires.
+    pub expires_at: i64,
+    /// `chatgpt_account_id` from the access-token JWT.
+    pub account_id: String,
+}
+
+impl OpenAiCodexCredential {
+    pub fn is_expired_or_near(&self) -> bool {
+        self.expires_at - EARLY_REFRESH_SECS <= Utc::now().timestamp()
+    }
+}
+
+/// Path of the stored credential: `~/.grok/openai_auth.json`.
+pub fn credential_path() -> PathBuf {
+    crate::util::grok_home::grok_home().join("openai_auth.json")
+}
+
+/// Read the stored credential, if any. Corrupt files read as `None`.
+pub fn read_credential() -> Option<OpenAiCodexCredential> {
+    let raw = std::fs::read_to_string(credential_path()).ok()?;
+    match serde_json::from_str(&raw) {
+        Ok(cred) => Some(cred),
+        Err(e) => {
+            tracing::warn!(error = %e, "openai auth: failed to parse openai_auth.json");
+            None
+        }
+    }
+}
+
+/// Persist the credential with owner-only permissions.
+pub fn store_credential(cred: &OpenAiCodexCredential) -> anyhow::Result<()> {
+    let path = credential_path();
+    if let Some(parent) = path.parent() {
+        std::fs::create_dir_all(parent)
+            .with_context(|| format!("creating {}", parent.display()))?;
+    }
+    let json = serde_json::to_string_pretty(cred)?;
+    std::fs::write(&path, json).with_context(|| format!("writing {}", path.display()))?;
+    #[cfg(unix)]
+    {
+        use std::os::unix::fs::PermissionsExt;
+        let _ = std::fs::set_permissions(&path, std::fs::Permissions::from_mode(0o600));
+    }
+    Ok(())
+}
+
+/// Delete the stored credential. Returns `true` if a file was removed.
+pub fn clear_credential() -> anyhow::Result<bool> {
+    match std::fs::remove_file(credential_path()) {
+        Ok(()) => Ok(true),
+        Err(e) if e.kind() == std::io::ErrorKind::NotFound => Ok(false),
+        Err(e) => Err(e.into()),
+    }
+}
+
+// ============================================================================
+// JWT / token plumbing
+// ============================================================================
+
+/// Extract `chatgpt_account_id` from the access-token JWT payload.
+pub(crate) fn extract_account_id(access_token: &str) -> anyhow::Result<String> {
+    let payload_b64 = access_token
+        .split('.')
+        .nth(1)
+        .ok_or_else(|| anyhow!("access token is not a JWT"))?;
+    let payload = URL_SAFE_NO_PAD
+        .decode(payload_b64)
+        .context("access token payload is not base64url")?;
+    let value: serde_json::Value =
+        serde_json::from_slice(&payload).context("access token payload is not JSON")?;
+    value
+        .get(JWT_CLAIM_PATH)
+        .and_then(|auth| auth.get("chatgpt_account_id"))
+        .and_then(|id| id.as_str())
+        .filter(|id| !id.is_empty())
+        .map(str::to_owned)
+        .ok_or_else(|| anyhow!("no chatgpt_account_id in access token"))
+}
+
+#[derive(Debug, Deserialize)]
+struct TokenResponse {
+    access_token: String,
+    refresh_token: String,
+    expires_in: i64,
+}
+
+fn credential_from_token_response(tokens: TokenResponse) -> anyhow::Result<OpenAiCodexCredential> {
+    let account_id = extract_account_id(&tokens.access_token)?;
+    Ok(OpenAiCodexCredential {
+        access_token: tokens.access_token,
+        refresh_token: tokens.refresh_token,
+        expires_at: Utc::now().timestamp() + tokens.expires_in,
+        account_id,
+    })
+}
+
+async fn read_token_response(
+    response: reqwest::Response,
+    operation: &str,
+) -> anyhow::Result<TokenResponse> {
+    let status = response.status();
+    let body = response.text().await.unwrap_or_default();
+    if !status.is_success() {
+        bail!("OpenAI token {operation} failed ({status}): {body}");
+    }
+    serde_json::from_str(&body)
+        .with_context(|| format!("OpenAI token {operation} response missing fields: {body}"))
+}
+
+async fn exchange_authorization_code(
+    code: &str,
+    code_verifier: &str,
+    redirect_uri: &str,
+) -> anyhow::Result<OpenAiCodexCredential> {
+    let response = reqwest::Client::new()
+        .post(token_url())
+        .form(&[
+            ("grant_type", "authorization_code"),
+            ("client_id", CLIENT_ID),
+            ("code", code),
+            ("code_verifier", code_verifier),
+            ("redirect_uri", redirect_uri),
+        ])
+        .send()
+        .await
+        .context("OpenAI token exchange request failed")?;
+    credential_from_token_response(read_token_response(response, "exchange").await?)
+}
+
+/// Refresh the access token with the stored refresh token.
+pub async fn refresh_credential(refresh_token: &str) -> anyhow::Result<OpenAiCodexCredential> {
+    let response = reqwest::Client::new()
+        .post(token_url())
+        .form(&[
+            ("grant_type", "refresh_token"),
+            ("refresh_token", refresh_token),
+            ("client_id", CLIENT_ID),
+        ])
+        .send()
+        .await
+        .context("OpenAI token refresh request failed")?;
+    let cred = credential_from_token_response(read_token_response(response, "refresh").await?)?;
+    store_credential(&cred)?;
+    Ok(cred)
+}
+
+/// Read the stored credential, refreshing (and persisting) when near expiry.
+pub async fn ensure_fresh_credential() -> anyhow::Result<OpenAiCodexCredential> {
+    let cred = read_credential()
+        .ok_or_else(|| anyhow!("not signed in to OpenAI. Run `grok openai login` first"))?;
+    if !cred.is_expired_or_near() {
+        return Ok(cred);
+    }
+    tracing::info!("openai auth: access token near expiry, refreshing");
+    refresh_credential(&cred.refresh_token).await
+}
+
+/// Process-wide single-flight guard for [`current_bearer_blocking`] refreshes.
+static REFRESH_LOCK: Mutex<()> = Mutex::new(());
+
+/// Synchronous bearer lookup for the sampler's `BearerResolver` seam.
+///
+/// Reads the credential from disk; when near expiry, performs a blocking
+/// refresh on a dedicated thread (safe to call from async contexts — the
+/// HTTP call runs on its own thread with its own runtime).
+pub fn current_bearer_blocking() -> Option<String> {
+    let cred = read_credential()?;
+    if !cred.is_expired_or_near() {
+        return Some(cred.access_token);
+    }
+    let _guard = REFRESH_LOCK.lock().ok()?;
+    // Re-read: another thread may have refreshed while we waited on the lock.
+    let cred = read_credential()?;
+    if !cred.is_expired_or_near() {
+        return Some(cred.access_token);
+    }
+    let refresh_token = cred.refresh_token.clone();
+    let result = std::thread::spawn(move || {
+        tokio::runtime::Builder::new_current_thread()
+            .enable_all()
+            .build()
+            .map_err(anyhow::Error::from)
+            .and_then(|rt| rt.block_on(refresh_credential(&refresh_token)))
+    })
+    .join();
+    match result {
+        Ok(Ok(fresh)) => Some(fresh.access_token),
+        Ok(Err(e)) => {
+            tracing::warn!(error = %e, "openai auth: token refresh failed");
+            // Serve the stale token; the request will 401 with a clear error.
+            Some(cred.access_token)
+        }
+        Err(_) => Some(cred.access_token),
+    }
+}
+
+// ============================================================================
+// PKCE
+// ============================================================================
+
+struct Pkce {
+    verifier: String,
+    challenge: String,
+}
+
+fn generate_pkce() -> Pkce {
+    use rand::RngCore;
+    let mut random_bytes = [0u8; 32];
+    rand::rng().fill_bytes(&mut random_bytes);
+    let verifier = URL_SAFE_NO_PAD.encode(random_bytes);
+    let challenge = URL_SAFE_NO_PAD.encode(Sha256::digest(verifier.as_bytes()));
+    Pkce {
+        verifier,
+        challenge,
+    }
+}
+
+fn build_authorize_url(pkce: &Pkce, state: &str) -> String {
+    let mut url = url::Url::parse(&authorize_url()).expect("static authorize URL parses");
+    url.query_pairs_mut()
+        .append_pair("response_type", "code")
+        .append_pair("client_id", CLIENT_ID)
+        .append_pair("redirect_uri", REDIRECT_URI)
+        .append_pair("scope", SCOPE)
+        .append_pair("code_challenge", &pkce.challenge)
+        .append_pair("code_challenge_method", "S256")
+        .append_pair("state", state)
+        .append_pair("id_token_add_organizations", "true")
+        .append_pair("codex_cli_simplified_flow", "true")
+        .append_pair("originator", ORIGINATOR);
+    url.to_string()
+}
+
+// ============================================================================
+// Browser login (loopback callback on port 1455 + stdin paste fallback)
+// ============================================================================
+
+#[derive(Debug)]
+struct Callback {
+    code: String,
+    state: String,
+}
+
+type CallbackResult = Result<Callback, String>;
+
+/// Parse a pasted redirect URL, `code#state` pair, or bare code.
+fn parse_pasted_input(input: &str) -> Option<Callback> {
+    let input = input.trim();
+    if input.is_empty() {
+        return None;
+    }
+    if let Ok(url) = url::Url::parse(input) {
+        let params: HashMap<String, String> = url.query_pairs().into_owned().collect();
+        if let Some(code) = params.get("code") {
+            return Some(Callback {
+                code: code.clone(),
+                state: params.get("state").cloned().unwrap_or_default(),
+            });
+        }
+        return None;
+    }
+    if let Some((code, state)) = input.split_once('#') {
+        return Some(Callback {
+            code: code.to_owned(),
+            state: state.to_owned(),
+        });
+    }
+    Some(Callback {
+        code: input.to_owned(),
+        state: String::new(),
+    })
+}
+
+fn callback_page(title: &str, message: &str) -> String {
+    format!(
+        r#"<!DOCTYPE html>
+<html lang="en"><head><meta charset="utf-8"/><meta name="color-scheme" content="light dark"/>
+<title>{title}</title>
+<style>body{{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
+display:flex;align-items:center;justify-content:center;min-height:100vh;background:#0a0a0a;color:#e5e5e5}}
+.card{{text-align:center;padding:48px}}h1{{font-size:18px;font-weight:600}}p{{font-size:14px;color:#a3a3a3}}
+@media(prefers-color-scheme:light){{body{{background:#fafafa;color:#171717}}p{{color:#525252}}}}</style>
+</head><body><div class="card"><h1>{title}</h1><p>{message}</p></div></body></html>"#
+    )
+}
+
+async fn handle_callback(
+    State(tx): State<tokio::sync::mpsc::Sender<CallbackResult>>,
+    Query(params): Query<HashMap<String, String>>,
+) -> (StatusCode, Html<String>) {
+    let result = if let Some(code) = params.get("code") {
+        Ok(Callback {
+            code: code.clone(),
+            state: params.get("state").cloned().unwrap_or_default(),
+        })
+    } else {
+        let error = params.get("error").cloned().unwrap_or_default();
+        let desc = params.get("error_description").cloned().unwrap_or_default();
+        Err(if desc.is_empty() {
+            error
+        } else {
+            format!("{error}: {desc}")
+        })
+    };
+    let response = match &result {
+        Ok(_) => (
+            StatusCode::OK,
+            Html(callback_page(
+                "Signed in to OpenAI",
+                "You can close this window and return to Grok Build.",
+            )),
+        ),
+        Err(_) => (
+            StatusCode::OK,
+            Html(callback_page(
+                "Sign-in failed",
+                "Close this window and try again.",
+            )),
+        ),
+    };
+    if let Err(e) = tx.try_send(result) {
+        tracing::error!(?e, "openai auth: callback channel send failed");
+    }
+    response
+}
+
+fn spawn_stdin_reader(tx: tokio::sync::mpsc::Sender<CallbackResult>) {
+    tokio::task::spawn_blocking(move || {
+        use std::io::BufRead;
+        let stdin = std::io::stdin();
+        loop {
+            if tx.is_closed() {
+                return;
+            }
+            let mut buf = String::new();
+            match stdin.lock().read_line(&mut buf) {
+                Ok(0) | Err(_) => return,
+                Ok(_) => {}
+            }
+            let trimmed = buf.trim();
+            if trimmed.is_empty() {
+                continue;
+            }
+            match parse_pasted_input(trimmed) {
+                Some(cb) => {
+                    let _ = tx.blocking_send(Ok(cb));
+                    return;
+                }
+                None => eprintln!("  Could not parse input; paste the full redirect URL:"),
+            }
+        }
+    });
+}
+
+async fn login_browser() -> anyhow::Result<OpenAiCodexCredential> {
+    let pkce = generate_pkce();
+    let state = uuid::Uuid::new_v4().simple().to_string();
+    let auth_url = build_authorize_url(&pkce, &state);
+
+    let listener = TcpListener::bind(("127.0.0.1", CALLBACK_PORT))
+        .await
+        .map_err(|e| {
+            anyhow!(
+                "could not bind 127.0.0.1:{CALLBACK_PORT} for the OpenAI login callback \
+                 ({e}). Close the conflicting program or use `grok openai login --device-code`."
+            )
+        })?;
+
+    let (tx, mut rx) = tokio::sync::mpsc::channel::<CallbackResult>(1);
+    let (shutdown_tx, shutdown_rx) = tokio::sync::oneshot::channel::<()>();
+    let app = Router::new()
+        .route("/auth/callback", get(handle_callback))
+        .with_state(tx.clone());
+    let server = tokio::spawn(async move {
+        let _ = axum::serve(listener, app)
+            .with_graceful_shutdown(async {
+                let _ = shutdown_rx.await;
+            })
+            .await;
+    });
+
+    eprintln!();
+    eprintln!("Signing in to OpenAI (ChatGPT)...");
+    eprintln!();
+    if let Err(e) = webbrowser::open(&auth_url) {
+        tracing::debug!(error = %e, "openai auth: failed to open browser");
+    }
+    eprintln!("Open this URL to sign in:");
+    eprintln!("  {auth_url}");
+    let use_stdin = std::io::stdin().is_terminal();
+    if use_stdin {
+        eprintln!();
+        eprintln!("Paste the redirect URL here if the browser can't reach this machine:");
+        spawn_stdin_reader(tx.clone());
+    }
+    drop(tx);
+
+    let callback = tokio::time::timeout(AUTH_CALLBACK_TIMEOUT, rx.recv())
+        .await
+        .map_err(|_| anyhow!("timed out waiting for the OpenAI login callback"))?
+        .ok_or_else(|| anyhow!("OpenAI login callback channel closed"))?
+        .map_err(|e| anyhow!("OpenAI sign-in failed: {e}"))?;
+
+    let _ = shutdown_tx.send(());
+    let _ = server.await;
+
+    if !callback.state.is_empty() && callback.state != state {
+        bail!("OpenAI sign-in failed: state mismatch");
+    }
+    exchange_authorization_code(&callback.code, &pkce.verifier, REDIRECT_URI).await
+}

+
+    fn build_test_jwt(payload_json: &str) -> String {
+        let header = URL_SAFE_NO_PAD.encode(r#"{"alg":"RS256","typ":"JWT"}"#);
+        let payload = URL_SAFE_NO_PAD.encode(payload_json);
+        format!("{header}.{payload}.fake-signature")
+    }
+
+    #[test]
+    fn extracts_account_id_from_jwt_claim() {
+        let token = build_test_jwt(
+            r#"{"https://api.openai.com/auth":{"chatgpt_account_id":"acct-123"},"exp":1}"#,
+        );
+        assert_eq!(extract_account_id(&token).unwrap(), "acct-123");
+    }
+
+    #[test]
+    fn rejects_jwt_without_account_id() {
+        let token = build_test_jwt(r#"{"exp":1}"#);
+        assert!(extract_account_id(&token).is_err());
+        assert!(extract_account_id("not-a-jwt").is_err());
+    }
+
+    #[test]
+    fn parses_pasted_redirect_url_code_hash_state_and_bare_code() {
+        let cb =
+            parse_pasted_input("http://localhost:1455/auth/callback?code=abc&state=xyz").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("abc", "xyz"));
+
+        let cb = parse_pasted_input("abc#xyz").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("abc", "xyz"));
+
+        let cb = parse_pasted_input("  bare-code  ").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("bare-code", ""));
+
+        assert!(parse_pasted_input("").is_none());
+        assert!(parse_pasted_input("http://localhost:1455/auth/callback?error=denied").is_none());
+    }
+
+    #[test]
+    fn authorize_url_carries_pkce_and_codex_params() {
+        let pkce = generate_pkce();
+        let url = build_authorize_url(&pkce, "st4te");
+        let parsed = url::Url::parse(&url).unwrap();
+        let params: HashMap<String, String> = parsed.query_pairs().into_owned().collect();
+        assert_eq!(params["client_id"], CLIENT_ID);
+        assert_eq!(params["redirect_uri"], REDIRECT_URI);
+        assert_eq!(params["code_challenge_method"], "S256");
+        assert_eq!(params["codex_cli_simplified_flow"], "true");
+        assert_eq!(params["originator"], ORIGINATOR);
+        assert_eq!(params["state"], "st4te");
+        assert_eq!(
+            params["code_challenge"],
+            URL_SAFE_NO_PAD.encode(Sha256::digest(pkce.verifier.as_bytes()))
+        );
+    }
+
+    #[test]
+    fn expiry_check_honors_early_refresh_window() {
+        let mut cred = OpenAiCodexCredential {
+            access_token: "a".into(),
+            refresh_token: "r".into(),
+            expires_at: Utc::now().timestamp() + 3600,
+            account_id: "acct".into(),
+        };
+        assert!(!cred.is_expired_or_near());
+        cred.expires_at = Utc::now().timestamp() + EARLY_REFRESH_SECS - 10;
+        assert!(cred.is_expired_or_near());
+    }
+}

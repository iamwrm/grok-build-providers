+    /// Built-in Anthropic catalog: every entry is keyed `anthropic/<slug>`,
+    /// routes to the Anthropic Messages API with the OAuth auth scheme, and
+    /// offers efforts through `max` (the wire value every adaptive Claude
+    /// model accepts).
+    #[test]
+    fn anthropic_entries_route_to_messages_backend() {
+        let entries = anthropic_model_entries();
+        assert!(!entries.is_empty());
+        assert!(entries.iter().any(|(k, _)| k == "anthropic/claude-opus-4-8"));
+        for (key, entry) in &entries {
+            assert_eq!(key, entry.info.id.as_deref().unwrap());
+            let slug = key.strip_prefix("anthropic/").unwrap();
+            assert_eq!(entry.info.model, slug);
+            assert_eq!(entry.info.base_url, ANTHROPIC_MESSAGES_BASE_URL);
+            assert_eq!(entry.info.api_backend, ApiBackend::Messages);
+            assert_eq!(entry.info.auth_scheme, AuthScheme::AnthropicOauth);
+            assert!(entry.info.supports_reasoning_effort);
+            assert!(
+                entry
+                    .info
+                    .reasoning_efforts
+                    .iter()
+                    .any(|o| o.value == ReasoningEffort::Max)
+            );
+            assert!(entry.info.max_completion_tokens.is_some());
+            assert!(entry.api_key.is_none() && entry.env_key.is_none());
+        }
+    }
+
     /// Anthropic OAuth headers: defaults injected, explicit user headers win.

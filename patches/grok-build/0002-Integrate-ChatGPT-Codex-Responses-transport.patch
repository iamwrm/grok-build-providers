+/// Fold the ChatGPT Codex backend headers into `extra_headers` for models
+/// with `auth_scheme = "chatgpt_oauth"`:
+///
+/// * `chatgpt-account-id` — from the stored OpenAI credential (required by
+///   the ChatGPT backend),
+/// * `originator` — client identifier gated by the backend,
+/// * `OpenAI-Beta: responses=experimental` — opts in to the Codex Responses
+///   surface.
+///
+/// Explicit user-provided headers win (entries are only inserted when the
+/// key is absent).
+pub fn inject_openai_codex_headers(extra_headers: &mut IndexMap<String, String>) {
+    if let Some(cred) = crate::auth::openai_codex::read_credential() {
+        extra_headers
+            .entry("chatgpt-account-id".to_string())
+            .or_insert(cred.account_id);
+    }
+    extra_headers
+        .entry("originator".to_string())
+        .or_insert_with(|| crate::auth::openai_codex::ORIGINATOR.to_string());
+    extra_headers
+        .entry("OpenAI-Beta".to_string())
+        .or_insert_with(|| "responses=experimental".to_string());
+}

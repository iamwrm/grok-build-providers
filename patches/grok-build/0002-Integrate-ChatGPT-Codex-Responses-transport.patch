+/// Rewrite a serialized Responses request for the ChatGPT Codex backend
+/// (`https://chatgpt.com/backend-api/codex/responses`), used by models with
+/// [`AuthScheme::ChatgptOauth`]. The ChatGPT backend deviates from the plain
+/// OpenAI Responses API:
+///
+/// * system-role input items are rejected — hoisted into `instructions`;
+/// * `store` must be `false`;
+/// * `reasoning.summary` accepts `auto` (not `concise`);
+/// * sampling params (`max_output_tokens`, `temperature`, `top_p`) are
+///   rejected for codex models and stripped.
+fn apply_chatgpt_codex_request_shape(body: &mut serde_json::Value) {
+    let Some(obj) = body.as_object_mut() else {
+        return;
+    };
+
+    let mut instructions_parts: Vec<String> = Vec::new();
+    if let Some(input) = obj.get_mut("input").and_then(|v| v.as_array_mut()) {
+        input.retain(|item| {
+            let is_system = item.get("role").and_then(|r| r.as_str()) == Some("system");
+            if is_system && let Some(text) = extract_input_message_text(item) {
+                instructions_parts.push(text);
+            }
+            // Streaming summary fallback creates a display-only reasoning
+            // sibling with no upstream id/signature. Codex requires reasoning
+            // input ids to be non-empty and pi likewise replays reasoning only
+            // when it has a signed reasoning item.
+            let is_unsigned_reasoning = item.get("type").and_then(|v| v.as_str())
+                == Some("reasoning")
+                && item
+                    .get("id")
+                    .and_then(|v| v.as_str())
+                    .is_none_or(str::is_empty);
+            !is_system && !is_unsigned_reasoning
+        });
+        // The ChatGPT Codex backend expects prior assistant turns in output
+        // message form, not the Responses API's permissive easy-input form.
+        // The first turn has no assistant history (and therefore works either
+        // way); without this normalization subsequent turns may emit reasoning
+        // but no final answer and get retried as empty.
+        for (index, item) in input.iter_mut().enumerate() {
+            normalize_codex_assistant_history_item(item, index);
+        }
+    }
+    if !instructions_parts.is_empty() {
+        obj.insert(
+            "instructions".to_string(),
+            serde_json::Value::String(instructions_parts.join("\n\n")),
+        );
+    } else if obj
+        .get("instructions")
+        .is_none_or(serde_json::Value::is_null)
+    {
+        obj.insert(
+            "instructions".to_string(),
+            serde_json::Value::String("You are a helpful assistant.".to_string()),
+        );
+    }
+
+    obj.insert("store".to_string(), serde_json::Value::Bool(false));
+    if let Some(reasoning) = obj.get_mut("reasoning").and_then(|v| v.as_object_mut()) {
+        reasoning.insert(
+            "summary".to_string(),
+            serde_json::Value::String("auto".to_string()),
+        );
+    }
+    obj.remove("max_output_tokens");
+    obj.remove("temperature");
+    obj.remove("top_p");
+}
+
+/// Convert a prior assistant easy-input message into the completed output
+/// message shape used by pi/the Codex client:
+///
+/// `{type:message, role:assistant, content:[{type:output_text, ...}],
+///   status:completed, id:msg_grok_N}`.
+fn normalize_codex_assistant_history_item(item: &mut serde_json::Value, index: usize) {
+    let Some(message) = item.as_object_mut() else {
+        return;
+    };
+    if message.get("role").and_then(|r| r.as_str()) != Some("assistant") {
+        return;
+    }
+    let Some(content) = message.get("content").cloned() else {
+        return;
+    };
+    let output_parts: Vec<serde_json::Value> = match content {
+        serde_json::Value::String(text) if !text.is_empty() => {
+            vec![codex_output_text_part(text)]
+        }
+        serde_json::Value::Array(parts) => parts
+            .into_iter()
+            .filter_map(|part| {
+                let text = part
+                    .get("text")
+                    .and_then(|v| v.as_str())
+                    .filter(|text| !text.is_empty())?;
+                Some(codex_output_text_part(text.to_string()))
+            })
+            .collect(),
+        _ => Vec::new(),
+    };
+    if output_parts.is_empty() {
+        return;
+    }
+    message.insert(
+        "content".to_string(),
+        serde_json::Value::Array(output_parts),
+    );
+    message.insert(
+        "type".to_string(),
+        serde_json::Value::String("message".to_string()),
+    );
+    message.insert(
+        "status".to_string(),
+        serde_json::Value::String("completed".to_string()),
+    );
+    message
+        .entry("id".to_string())
+        .or_insert_with(|| serde_json::Value::String(format!("msg_grok_{index}")));
+}
+
+fn codex_output_text_part(text: String) -> serde_json::Value {
+    serde_json::json!({
+        "type": "output_text",
+        "text": text,
+        "annotations": [],
+    })
+}
+
+/// Text of an easy-input message item: string content or the concatenated
+/// `text` fields of its content parts.
+fn extract_input_message_text(item: &serde_json::Value) -> Option<String> {
+    match item.get("content")? {
+        serde_json::Value::String(s) => Some(s.clone()),
+        serde_json::Value::Array(parts) => {
+            let texts: Vec<&str> = parts
+                .iter()
+                .filter_map(|p| p.get("text").and_then(|t| t.as_str()))
+                .collect();
+            if texts.is_empty() {
+                None
+            } else {
+                Some(texts.join("\n"))
+            }
+        }
+        _ => None,
+    }
+}
+
 fn agent_version() -> String {
     xai_grok_version::VERSION.to_string()
 }

+pub struct OpenAiCodexBearerResolver;
+
+impl xai_grok_sampler::BearerResolver for OpenAiCodexBearerResolver {
+    fn current_bearer(&self) -> Option<String> {
+        current_bearer_blocking()
+    }
+}

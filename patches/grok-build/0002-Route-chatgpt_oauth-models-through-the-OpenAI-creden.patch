+
+    /// ChatGPT Codex request shape: system input items hoist into
+    /// `instructions`, `store` forces false, `reasoning.summary` becomes
+    /// `auto`, and sampling params the backend rejects are stripped.
+    #[test]
+    fn chatgpt_codex_shape_hoists_system_and_strips_rejected_params() {
+        let mut body = serde_json::json!({
+            "model": "gpt-5.5",
+            "input": [
+                {"type": "message", "role": "system", "content": "You are Grok."},
+                {"type": "message", "role": "user", "content": "hi"},
+            ],
+            "store": true,
+            "max_output_tokens": 128,
+            "temperature": 0.7,
+            "top_p": 0.9,
+            "reasoning": {"effort": "high", "summary": "concise"},
+        });
+        apply_chatgpt_codex_request_shape(&mut body);
+        assert_eq!(body["instructions"], "You are Grok.");
+        let input = body["input"].as_array().unwrap();
+        assert_eq!(input.len(), 1);
+        assert_eq!(input[0]["role"], "user");
+        assert_eq!(body["store"], false);
+        assert_eq!(body["reasoning"]["summary"], "auto");
+        assert_eq!(body["reasoning"]["effort"], "high");
+        assert!(body.get("max_output_tokens").is_none());
+        assert!(body.get("temperature").is_none());
+        assert!(body.get("top_p").is_none());
+    }
+
+    /// No system item and no instructions → a default instructions string is
+    /// injected (the ChatGPT backend rejects requests without one). Content
+    /// parts arrays are flattened.
+    #[test]
+    fn chatgpt_codex_shape_defaults_instructions_and_flattens_parts() {
+        let mut body = serde_json::json!({
+            "model": "gpt-5.5",
+            "input": [
+                {"type": "message", "role": "user", "content": "hi"},
+            ],
+        });
+        apply_chatgpt_codex_request_shape(&mut body);
+        assert_eq!(body["instructions"], "You are a helpful assistant.");
+        assert_eq!(body["store"], false);
+
+        let mut body = serde_json::json!({
+            "input": [
+                {"type": "message", "role": "system", "content": [
+                    {"type": "input_text", "text": "part one"},
+                    {"type": "input_text", "text": "part two"},
+                ]},
+            ],
+        });
+        apply_chatgpt_codex_request_shape(&mut body);
+        assert_eq!(body["instructions"], "part one\npart two");
+        assert!(body["input"].as_array().unwrap().is_empty());
+    }
 }

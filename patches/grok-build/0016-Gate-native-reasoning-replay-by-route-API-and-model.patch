+/// Foreign/legacy reasoning must not emit native provider state:
+/// 1. encrypted/signature blobs fail verification on another route;
+/// 2. Responses `rs_…` ids under `store: false` produce 404 lookups;
+/// 3. Anthropic thinking signatures are valid only for their origin.
+///
+/// Visible summary/content is folded into the following assistant text (pi
+/// converts foreign thinking to plain text). Opaque-only items are dropped.
+/// This is wire-time only: history remains unchanged, so switching back to the
+/// exact original origin restores native replay.
+fn sanitize_reasoning_for_origin(
+    items: &[ConversationItem],
+    destination: Option<&crate::ReasoningOrigin>,
+) -> Vec<ConversationItem> {
+    let mut out = Vec::with_capacity(items.len());
+    let mut pending_foreign_text: Vec<String> = Vec::new();
+
+    let flush_foreign_text = |pending: &mut Vec<String>, assistant: &mut AssistantItem| {
+        if pending.is_empty() {
+            return;
+        }
+        let prefix = pending.join("\n");
+        pending.clear();
+        if assistant.content.is_empty() {
+            assistant.content = Arc::<str>::from(prefix);
+        } else {
+            assistant.content =
+                Arc::<str>::from(format!("{prefix}\n\n{}", assistant.content.as_ref()));
+        }
+    };
+
+    for (idx, item) in items.iter().enumerate() {
+        match item {
+            ConversationItem::Reasoning(r) => {
+                let source = source_assistant_for_reasoning_at(items, idx)
+                    .and_then(|assistant| assistant.reasoning_origin.as_ref());
+                if reasoning_item_compatible(source, destination) {
+                    out.push(item.clone());
+                    continue;
+                }
+                // Foreign: never emit typed reasoning. Keep visible CoT as
+                // text to prepend onto the following assistant (pi-style).
+                let text = reasoning_item_text(r);
+                if !text.trim().is_empty() {
+                    pending_foreign_text.push(text);
+                }
+            }
+            ConversationItem::Assistant(a) => {
+                let mut a = a.clone();
+                flush_foreign_text(&mut pending_foreign_text, &mut a);
+                out.push(ConversationItem::Assistant(a));
+            }
+            ConversationItem::BackendToolCall(_) => {
+                // Stay between reasoning and assistant; do not flush yet.
+                out.push(item.clone());
+            }
+            other => {
+                // User/system/tool-result interrupts: orphan foreign text
+                // becomes a standalone assistant message so it is not lost,
+                // then the interrupting item follows.
+                if !pending_foreign_text.is_empty() {
+                    let text = pending_foreign_text.join("\n");
+                    pending_foreign_text.clear();
+                    out.push(ConversationItem::assistant(text));
+                }
+                out.push(other.clone());
+            }
+        }
+    }
+    if !pending_foreign_text.is_empty() {
+        let text = pending_foreign_text.join("\n");
+        out.push(ConversationItem::assistant(text));
+    }
+    out
+}

+/// Native reasoning may be replayed only when the persisted source and actual
+/// destination agree on route, API backend, and wire model. Real sampler
+/// requests always stamp the destination, so missing source provenance fails
+/// closed. The `(None, None)` case remains only for legacy pure conversions.
+fn reasoning_item_compatible(
+    source: Option<&crate::ReasoningOrigin>,
+    destination: Option<&crate::ReasoningOrigin>,
+) -> bool {
+    match (source, destination) {
+        (Some(src), Some(dst)) => src == dst,
+        // Pure conversion helpers and old unit fixtures have neither side;
+        // preserve their historical shape. Real sampler requests always stamp
+        // a destination, so legacy history (`None` source) still fails closed.
+        (None, None) => true,
+        _ => false,
+    }
+}

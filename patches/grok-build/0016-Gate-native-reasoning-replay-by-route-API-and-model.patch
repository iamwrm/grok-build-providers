+        let original = serde_json::to_string(&items).unwrap();
+        let foreign = request_with_origin(
+            items.clone(),
+            "https://api.x.ai/v1",
+            crate::ApiBackend::Responses,
+            "grok-4.5",
+        );
+        let foreign_wire = serde_json::to_string(&input_items_json(&foreign)).unwrap();
+        assert!(!foreign_wire.contains("restore_me"));

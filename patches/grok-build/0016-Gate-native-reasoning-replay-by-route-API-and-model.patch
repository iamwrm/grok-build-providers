+/// Normalize an inference route before persisting it as reasoning provenance.
+/// Strip credentials, query, fragment, and trailing slashes: none affects the
+/// provider identity, and none should be copied into chat history.
+pub(crate) fn reasoning_route(base_url: &str) -> String {
+    let Ok(mut url) = reqwest::Url::parse(base_url) else {
+        return base_url.trim_end_matches('/').to_owned();
+    };
+    let _ = url.set_username("");
+    let _ = url.set_password(None);
+    url.set_query(None);
+    url.set_fragment(None);
+    url.as_str().trim_end_matches('/').to_owned()
+}

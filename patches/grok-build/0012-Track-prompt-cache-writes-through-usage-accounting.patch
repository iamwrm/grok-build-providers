+
+/// Read `response.usage.input_tokens_details.cache_write_tokens` from a raw
+/// terminal Responses event. OpenAI currently reports 0 (automatic prompt
+/// cache writes are not separately billed), but preserving the wire field
+/// keeps the normalized accounting provider-neutral.
+fn extract_cache_write_tokens(value: &serde_json::Value) -> Option<u32> {
+    u32::try_from(
+        value
+            .pointer("/response/usage/input_tokens_details/cache_write_tokens")?
+            .as_u64()?,
+    )
+    .ok()
+}
 

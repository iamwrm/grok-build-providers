+/// Split a pi-style single-token model reference `<model>[:<effort>]`,
+/// e.g. `-m openai-codex/gpt-5.5:xhigh`.
+///
+/// The suffix after the **last** colon is treated as a reasoning effort only
+/// when it parses as a canonical effort token (`none|minimal|low|medium|
+/// high|xhigh|max`), so model ids that themselves contain colons keep
+/// resolving as plain ids. An explicit `--effort` flag wins over the suffix
+/// at the call sites.
+pub fn split_model_effort_reference(model: Option<&str>) -> (Option<String>, Option<String>) {
+    let Some(model) = model else {
+        return (None, None);
+    };
+    if let Some((prefix, suffix)) = model.rsplit_once(':')
+        && !prefix.is_empty()
+        && xai_grok_shell::sampling::types::parse_canonical_effort_token(suffix).is_some()
+    {
+        return (Some(prefix.to_string()), Some(suffix.to_ascii_lowercase()));
+    }
+    (Some(model.to_string()), None)
+}

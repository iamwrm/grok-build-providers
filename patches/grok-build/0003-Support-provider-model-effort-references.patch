+    /// pi-style `/model <id>:<effort>` single-token reference resolves the
+    /// prefix as a model and the suffix as its effort.
+    #[test]
+    fn run_parses_colon_effort_reference() {
+        let mut state = ModelState::default();
+        let (id, info) = model_with_reasoning("openai-codex/gpt-5.5", "GPT-5.5 (ChatGPT)");
+        state.available.insert(id, info);
+        let mut ctx = dummy_exec_ctx(&state);
+        let result = ModelCommand.run(&mut ctx, "openai-codex/gpt-5.5:xhigh");
+        match result {
+            CommandResult::Action(Action::SwitchModel { model_id, effort }) => {
+                assert_eq!(model_id.0.as_ref(), "openai-codex/gpt-5.5");
+                assert_eq!(effort, Some(ReasoningEffort::Xhigh));
+            }
+            other => panic!("expected SwitchModel with effort, got {other:?}"),
+        }
+    }
+
+    /// A model id that itself ends in a colon-suffix which is NOT an effort
+    /// keeps resolving via the exact-match path, not the colon-split path.
+    #[test]
+    fn run_colon_in_model_id_still_resolves_exactly() {
+        let mut state = ModelState::default();
+        let (id, info) = model_with_reasoning("vendor/model:exacto", "Vendor Exacto");
+        state.available.insert(id.clone(), info);
+        let mut ctx = dummy_exec_ctx(&state);
+        let result = ModelCommand.run(&mut ctx, "vendor/model:exacto");
+        match result {
+            CommandResult::Action(Action::SetDefaultModel(resolved_id)) => {
+                assert_eq!(resolved_id, id);
+            }
+            other => panic!("expected SetDefaultModel, got {other:?}"),
+        }
+    }

+        {
+            return match ctx.models.resolve_effort_for_model(&id, token.trim()) {
+                Ok(effort) => CommandResult::Action(Action::SwitchModel {
+                    model_id: id,
+                    effort: Some(effort),
+                }),
+                Err(err) => CommandResult::Error(err.message()),
+            };
+        }

+    #[test]
+    fn split_model_effort_reference_matrix() {
+        // (input, expected model, expected effort)
+        let cases: &[(Option<&str>, Option<&str>, Option<&str>)] = &[
+            (None, None, None),
+            (Some("grok-build"), Some("grok-build"), None),
+            (
+                Some("openai-codex/gpt-5.5:xhigh"),
+                Some("openai-codex/gpt-5.5"),
+                Some("xhigh"),
+            ),
+            (Some("gpt-5.5:MAX"), Some("gpt-5.5"), Some("max")),
+            // Non-effort suffix stays part of the model id.
+            (
+                Some("vendor/model:exacto"),
+                Some("vendor/model:exacto"),
+                None,
+            ),
+            // Colon in the middle: only the LAST segment is considered.
+            (
+                Some("vendor:model:high"),
+                Some("vendor:model"),
+                Some("high"),
+            ),
+            // Bare `:high` is not a model reference.
+            (Some(":high"), Some(":high"), None),
+        ];
+        for (input, model, effort) in cases {
+            let (m, e) = split_model_effort_reference(*input);
+            assert_eq!(m.as_deref(), *model, "model for {input:?}");
+            assert_eq!(e.as_deref(), *effort, "effort for {input:?}");
+        }
+    }

+
+    #[test]
+    fn parses_pasted_redirect_url_code_hash_state_and_bare_code() {
+        let cb = parse_pasted_input("http://localhost:53692/callback?code=abc&state=xyz").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("abc", "xyz"));
+
+        // claude.ai manual-copy format
+        let cb = parse_pasted_input("abc#xyz").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("abc", "xyz"));
+
+        let cb = parse_pasted_input("  bare-code  ").unwrap();
+        assert_eq!((cb.code.as_str(), cb.state.as_str()), ("bare-code", ""));
+
+        assert!(parse_pasted_input("").is_none());
+        assert!(parse_pasted_input("http://localhost:53692/callback?error=denied").is_none());
+    }
+
+    #[test]
+    fn authorize_url_carries_pkce_and_uses_verifier_as_state() {
+        let pkce = generate_pkce();
+        let url = build_authorize_url(&pkce);
+        let parsed = url::Url::parse(&url).unwrap();
+        let params: HashMap<String, String> = parsed.query_pairs().into_owned().collect();
+        assert_eq!(params["client_id"], CLIENT_ID);
+        assert_eq!(params["redirect_uri"], REDIRECT_URI);
+        assert_eq!(params["code"], "true");
+        assert_eq!(params["code_challenge_method"], "S256");
+        assert_eq!(params["state"], pkce.verifier);
+        assert_eq!(
+            params["code_challenge"],
+            URL_SAFE_NO_PAD.encode(Sha256::digest(pkce.verifier.as_bytes()))
+        );
+        assert!(params["scope"].contains("user:inference"));
+    }
+
+    #[test]
+    fn expiry_check_honors_early_refresh_window() {
+        let mut cred = AnthropicCredential {
+            access_token: "a".into(),
+            refresh_token: "r".into(),
+            expires_at: Utc::now().timestamp() + 3600,
+        };
+        assert!(!cred.is_expired_or_near());
+        cred.expires_at = Utc::now().timestamp() + EARLY_REFRESH_SECS - 10;
+        assert!(cred.is_expired_or_near());
+    }

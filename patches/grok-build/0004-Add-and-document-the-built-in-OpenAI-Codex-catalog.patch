@@ -5891,6 +5968,33 @@ reasoning_effort = "low"
     /// `try_resolve_model_credentials` — swaps it for the session token. BYOK
     /// (non-x.ai) own keys are preserved. (`try_resolve_model_credentials`
     /// loads global config, so this exercises its resolve + enforce core.)
+    /// Built-in Codex catalog: every entry is keyed `openai-codex/<slug>`,
+    /// routes to the ChatGPT Codex backend over the Responses API with the
+    /// ChatGPT OAuth scheme, and exposes the low..xhigh effort menu.
+    #[test]
+    fn openai_codex_entries_route_to_chatgpt_codex_backend() {
+        let entries = openai_codex_model_entries();
+        assert!(!entries.is_empty());
+        assert!(entries.iter().any(|(k, _)| k == "openai-codex/gpt-5.5"));
+        for (key, entry) in &entries {
+            assert_eq!(key, entry.info.id.as_deref().unwrap());
+            let slug = key.strip_prefix("openai-codex/").unwrap();
+            assert_eq!(entry.info.model, slug);
+            assert_eq!(entry.info.base_url, OPENAI_CODEX_BASE_URL);
+            assert_eq!(entry.info.api_backend, ApiBackend::Responses);
+            assert_eq!(entry.info.auth_scheme, AuthScheme::ChatgptOauth);
+            assert!(entry.info.supports_reasoning_effort);
+            assert!(
+                entry
+                    .info
+                    .reasoning_efforts
+                    .iter()
+                    .any(|o| o.value == ReasoningEffort::Xhigh)
+            );
+            assert!(entry.api_key.is_none() && entry.env_key.is_none());
+        }
+    }
+

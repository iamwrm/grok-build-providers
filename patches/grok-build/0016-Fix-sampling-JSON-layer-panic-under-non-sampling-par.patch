From daf1c0b74dbcfdb2b58a7f8ed4167a2f7cc7c689 Mon Sep 17 00:00:00 2001
From: grok-build-providers-verify <verify@invalid>
Date: Mon, 20 Jul 2026 19:29:16 +0800
Subject: [PATCH] Fix sampling JSON layer panic under non-sampling parent spans

The JSON fmt formatter walks every ancestor when writing the spans array
and panics if any lacks FormattedFields. RuntimeSamplingLayer only
recorded those fields for sampling_log spans, so the first request under
agent/shell parents crashed the ACP worker after /debug sampling on.

Always forward span lifecycle methods; keep gating only on event
emission. Disable span list / current-span serialization entirely so the
formatter never looks up FormattedFields (hard guarantee against the
tracing-subscriber panic). Add a regression test for both configs.
---
 .../xai-grok-telemetry/src/sampling_log.rs    | 168 +++++++++++++++---
 1 file changed, 139 insertions(+), 29 deletions(-)

diff --git a/crates/codegen/xai-grok-telemetry/src/sampling_log.rs b/crates/codegen/xai-grok-telemetry/src/sampling_log.rs
index 1f62a7b..53a872a 100644
--- a/crates/codegen/xai-grok-telemetry/src/sampling_log.rs
+++ b/crates/codegen/xai-grok-telemetry/src/sampling_log.rs
@@ -39,6 +39,14 @@ pub fn set_enabled(enabled: bool) -> bool {
 /// events return `Interest::sometimes()` so tracing never caches the startup
 /// state as permanently on or off. Non-sampling callsites remain globally
 /// enabled for the other layers in the subscriber stack.
+///
+/// Span lifecycle methods are always forwarded to the inner `fmt` layer. The
+/// JSON formatter walks *every* ancestor when writing the `spans` array and
+/// panics if any lacks `FormattedFields` (see tracing-subscriber
+/// `Unable to find FormattedFields in extensions`). Sampling events almost
+/// always fire under non-`sampling_log` agent/shell parents, so filtering
+/// `on_new_span` by target crashes the ACP worker the first time a request
+/// is logged. Only event emission is gated on target + runtime enable.
 struct RuntimeSamplingLayer<L, S> {
     inner: L,
     _subscriber: PhantomData<fn(S)>,
@@ -84,9 +92,9 @@ where
         id: &tracing::span::Id,
         ctx: Context<'_, S>,
     ) {
-        if attrs.metadata().target() == TARGET {
-            self.inner.on_new_span(attrs, id, ctx);
-        }
+        // Must run for every span: JSON `spans` list requires FormattedFields
+        // on all ancestors of a sampling event, not only sampling_log spans.
+        self.inner.on_new_span(attrs, id, ctx);
     }
 
     fn on_record(
@@ -95,12 +103,7 @@ where
         values: &tracing::span::Record<'_>,
         ctx: Context<'_, S>,
     ) {
-        if ctx
-            .metadata(span)
-            .is_some_and(|meta| meta.target() == TARGET)
-        {
-            self.inner.on_record(span, values, ctx);
-        }
+        self.inner.on_record(span, values, ctx);
     }
 
     fn on_follows_from(
@@ -109,12 +112,7 @@ where
         follows: &tracing::span::Id,
         ctx: Context<'_, S>,
     ) {
-        if ctx
-            .metadata(span)
-            .is_some_and(|meta| meta.target() == TARGET)
-        {
-            self.inner.on_follows_from(span, follows, ctx);
-        }
+        self.inner.on_follows_from(span, follows, ctx);
     }
 
     fn on_event(&self, event: &tracing::Event<'_>, ctx: Context<'_, S>) {
@@ -124,24 +122,15 @@ where
     }
 
     fn on_enter(&self, id: &tracing::span::Id, ctx: Context<'_, S>) {
-        if ctx.metadata(id).is_some_and(|meta| meta.target() == TARGET) {
-            self.inner.on_enter(id, ctx);
-        }
+        self.inner.on_enter(id, ctx);
     }
 
     fn on_exit(&self, id: &tracing::span::Id, ctx: Context<'_, S>) {
-        if ctx.metadata(id).is_some_and(|meta| meta.target() == TARGET) {
-            self.inner.on_exit(id, ctx);
-        }
+        self.inner.on_exit(id, ctx);
     }
 
     fn on_close(&self, id: tracing::span::Id, ctx: Context<'_, S>) {
-        if ctx
-            .metadata(&id)
-            .is_some_and(|meta| meta.target() == TARGET)
-        {
-            self.inner.on_close(id, ctx);
-        }
+        self.inner.on_close(id, ctx);
     }
 }
 
@@ -182,9 +171,17 @@ where
         *slot = Some(guard);
     }
 
+    // Hard guarantee against tracing-subscriber's
+    // `Unable to find FormattedFields in extensions` panic: the JSON
+    // formatter panics if it walks any ancestor that lacks FormattedFields
+    // for *this* layer's field type. Even with RuntimeSamplingLayer
+    // forwarding every on_new_span, other layers / interest caching /
+    // async span stacks can still leave gaps. Event fields alone carry
+    // the wire payload (request_body / sse_chunk); do not serialize spans.
     let fmt_layer = tracing_subscriber::fmt::layer()
         .json()
-        .with_current_span(false) // `spans` array already carries the full ancestor list
+        .with_current_span(false)
+        .with_span_list(false)
         .with_ansi(false)
         .with_timer(tracing_subscriber::fmt::time::UtcTime::rfc_3339())
         .with_target(false)
@@ -195,9 +192,11 @@ where
 
 #[cfg(test)]
 mod tests {
-    use std::sync::Arc;
+    use std::io::{self, Write};
+    use std::sync::{Arc, Mutex};
     use std::sync::atomic::{AtomicUsize, Ordering};
 
+    use tracing_subscriber::fmt::MakeWriter;
     use tracing_subscriber::layer::SubscriberExt as _;
 
     use super::*;
@@ -233,4 +232,115 @@ mod tests {
         set_enabled(original);
         assert_eq!(events.load(Ordering::Relaxed), 1);
     }
+
+    /// Shared buffer writer so the JSON fmt layer can be exercised in tests.
+    #[derive(Clone, Default)]
+    struct Buf(Arc<Mutex<Vec<u8>>>);
+
+    impl<'a> MakeWriter<'a> for Buf {
+        type Writer = BufWriter;
+
+        fn make_writer(&'a self) -> Self::Writer {
+            BufWriter(self.0.clone())
+        }
+    }
+
+    struct BufWriter(Arc<Mutex<Vec<u8>>>);
+
+    impl Write for BufWriter {
+        fn write(&mut self, buf: &[u8]) -> io::Result<usize> {
+            self.0.lock().expect("buf").write(buf)
+        }
+
+        fn flush(&mut self) -> io::Result<()> {
+            Ok(())
+        }
+    }
+
+    /// Regression for the TUI crash:
+    /// `Unable to find FormattedFields in extensions` when a sampling event
+    /// is emitted under a non-`sampling_log` parent span (the normal ACP path).
+    ///
+    /// Two cases:
+    /// 1. Production settings: span list off → never looks up FormattedFields.
+    /// 2. Span list on without recording parent fields → would panic; with
+    ///    full span forwarding it must still succeed.
+    #[test]
+    fn json_fmt_does_not_panic_under_non_sampling_parent_spans() {
+        let original = enabled();
+        set_enabled(true);
+
+        // Case 1: production config (no span list).
+        {
+            let buf = Buf::default();
+            let fmt_layer = tracing_subscriber::fmt::layer()
+                .json()
+                .with_current_span(false)
+                .with_span_list(false)
+                .with_ansi(false)
+                .with_target(false)
+                .with_writer(buf.clone());
+            let subscriber =
+                tracing_subscriber::registry().with(RuntimeSamplingLayer::new(fmt_layer));
+
+            tracing::subscriber::with_default(subscriber, || {
+                let agent = tracing::info_span!("agent_turn", turn = 1u64);
+                let _agent = agent.enter();
+                let sampling = tracing::info_span!(
+                    target: TARGET,
+                    "sampling_request",
+                    request_id = "req-test",
+                );
+                let _sampling = sampling.enter();
+                tracing::info!(
+                    target: TARGET,
+                    event = "request_body",
+                    backend = "responses",
+                    data = "{\"ok\":true}",
+                );
+            });
+
+            let written = String::from_utf8(buf.0.lock().expect("buf").clone()).expect("utf8");
+            assert!(
+                written.contains("request_body"),
+                "expected sampling event in log, got: {written}"
+            );
+            assert!(
+                !written.contains("\"spans\""),
+                "production layer must not emit spans list, got: {written}"
+            );
+        }
+
+        // Case 2: span list enabled + non-sampling parent (the old panic path).
+        {
+            let buf = Buf::default();
+            let fmt_layer = tracing_subscriber::fmt::layer()
+                .json()
+                .with_current_span(false)
+                .with_span_list(true)
+                .with_ansi(false)
+                .with_target(false)
+                .with_writer(buf.clone());
+            let subscriber =
+                tracing_subscriber::registry().with(RuntimeSamplingLayer::new(fmt_layer));
+
+            tracing::subscriber::with_default(subscriber, || {
+                let agent = tracing::info_span!("agent_turn", turn = 1u64);
+                let _agent = agent.enter();
+                tracing::info!(
+                    target: TARGET,
+                    event = "sse_chunk",
+                    data = "data: {}",
+                );
+            });
+
+            let written = String::from_utf8(buf.0.lock().expect("buf").clone()).expect("utf8");
+            assert!(
+                written.contains("sse_chunk"),
+                "expected sampling event with span list, got: {written}"
+            );
+        }
+
+        set_enabled(original);
+    }
 }
